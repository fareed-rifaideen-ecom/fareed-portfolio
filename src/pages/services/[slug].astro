---
// src/pages/services/[slug].astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubPageHeader from '../../components/SubPageHeader.astro';
import GlobalFooter from '../../components/GlobalFooter.astro';
import ContactModal from '../../components/ContactModal.astro';

// 1. Tell Astro to generate a route for every file in the 'services' collection
export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Extract the data for the specific page
const { entry } = Astro.props;

// 3. Fetch all services for the global footer loop
const allServices = await getCollection('services');
allServices.sort((a: any, b: any) => a.data.order - b.data.order);
---

<BaseLayout 
  title={`${entry.data.title} | Fareed M. Rifaideen`} 
  description={entry.data.summary}
>
  <SubPageHeader />

  <section class="service-hero global-padding">
    <div class="container">
      <div class="label-pill">
        <span class="pill-dot"></span>
        <span>Service Overview</span>
      </div>
      <h1 class="massive-service-title">{entry.data.title}</h1>
      <p class="service-lead">{entry.data.summary}</p>
      
      <div class="tech-tags service-hero-tags">
        {entry.data.techStack && entry.data.techStack.map((tech: string) => (
          <span class="tag">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="deployment-status-section global-padding">
    <div class="container launch-container">
      <div class="glass-vault">
        
        <div class="status-wrapper">
          <div class="status-dot"></div>
          <span class="status-text">Module Status: In Development</span>
        </div>

        <h2 class="massive-launch-title" id="decrypt-text">Structuring SOPs...</h2>
        
        <p class="launch-desc">
          Comprehensive technical breakdowns, execution logs, and case studies for <strong>{entry.data.title}</strong> are currently being formatted for public release.
        </p>

        <div class="terminal-progress">
          <div class="progress-info">
            <span>> compiling_service_data.sh</span>
            <span class="progress-percentage">Loading...</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill"></div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <GlobalFooter />
  <ContactModal />
</BaseLayout>

<style>
  /* Main Hero Section */
  .service-hero { margin-top: 15vh; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 6rem; }
  .massive-service-title { font-family: 'Syne', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); color: var(--text-primary); margin: 1.5rem 0; line-height: 1.1; letter-spacing: -0.02em; }
  .service-lead { font-family: 'Hanken Grotesk', sans-serif; font-size: 1.2rem; color: var(--text-secondary); max-width: 800px; line-height: 1.7; margin: 0; }
  .label-pill { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 50px; padding: 0.4rem 1.2rem; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; }
  .pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-primary); }
  
  .tech-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag { font-family: 'Hanken Grotesk', sans-serif; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.4rem 0.8rem; border: 1px solid rgba(255, 255, 255, 0.15); color: var(--text-secondary); transition: all 0.3s ease; border-radius: 50px; }
  .service-hero-tags { margin-top: 2.5rem; }

  /* In-Progress Terminal Vault Styles */
  .deployment-status-section { padding-top: 6rem; padding-bottom: 8rem; }
  .launch-container { display: flex; justify-content: flex-start; max-width: 800px; margin: 0 auto; }

  .glass-vault {
    background: linear-gradient(135deg, rgba(25, 25, 25, 0.6) 0%, rgba(10, 10, 10, 0.9) 100%);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255,255,255,0.1);
    border-radius: 24px; padding: 4rem; width: 100%; text-align: left; position: relative; overflow: hidden;
  }

  .status-wrapper { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 1.5rem; }
  .status-dot { width: 10px; height: 10px; background-color: #ffbd2e; border-radius: 50%; box-shadow: 0 0 10px #ffbd2e; animation: pulse-status 1.5s infinite alternate; }
  .status-text { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.85rem; color: #ffbd2e; text-transform: uppercase; letter-spacing: 0.1em; }

  @keyframes pulse-status { 0% { opacity: 0.4; box-shadow: 0 0 5px #ffbd2e; } 100% { opacity: 1; box-shadow: 0 0 15px #ffbd2e; } }

  .massive-launch-title { font-family: 'Syne', sans-serif; font-size: clamp(2rem, 4vw, 3rem); color: var(--text-primary); margin: 0 0 1.5rem 0; line-height: 1.1; letter-spacing: -0.02em; min-height: 3.5rem; }
  .launch-desc { font-family: 'Hanken Grotesk', sans-serif; font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; margin: 0; max-width: 550px; }
  .launch-desc strong { color: #fff; font-weight: 600; }

  /* Progress Bar Terminal effect */
  .terminal-progress { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .progress-info { display: flex; justify-content: space-between; font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8rem; color: #A3A3A3; margin-bottom: 0.8rem; }
  .progress-percentage { color: #27c93f; font-weight: 600; }
  
  .progress-track { width: 100%; height: 4px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; position: relative; }
  .progress-fill { position: absolute; top: 0; left: 0; height: 100%; width: 45%; background: #27c93f; border-radius: 4px; box-shadow: 0 0 10px #27c93f; animation: loading-shimmer 2s infinite linear; }

  @keyframes loading-shimmer { 0% { opacity: 0.6; } 50% { opacity: 1; } 100% { opacity: 0.6; } }

  @media (max-width: 768px) {
    .service-hero { margin-top: 12vh; padding-bottom: 4rem; }
    .deployment-status-section { padding-top: 3rem; }
    .glass-vault { padding: 2.5rem 1.5rem; }
    .massive-launch-title { min-height: 5rem; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { TextPlugin } from 'gsap/TextPlugin';

  gsap.registerPlugin(TextPlugin);

  document.addEventListener("DOMContentLoaded", () => {
    // Dynamic Text Scramble / Typewriter Effect
    const decryptText = document.getElementById("decrypt-text");
    
    if (decryptText) {
      let tl = gsap.timeline({ repeat: -1, repeatDelay: 3 });
      
      tl.to(decryptText, { duration: 1.5, text: "Structuring SOPs...", ease: "none", delay: 0.5 })
        .to(decryptText, { duration: 1.5, text: "Formatting Logs...", ease: "none", delay: 2 })
        .to(decryptText, { duration: 1.5, text: "Deployment Pending.", ease: "none", delay: 2 });
    }

    // Vault floating animation
    gsap.to(".glass-vault", {
      y: -10,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  });
</script>