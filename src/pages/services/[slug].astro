---
// src/pages/services/[slug].astro
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 1. Tell Astro to generate a route for every file in the 'services' collection
export async function getStaticPaths() {
  const serviceEntries = await getCollection('services');
  return serviceEntries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

// 2. Extract the data and Markdown content for the specific page being loaded
const { entry } = Astro.props;
const { Content } = await render(entry);

// 3. Fetch all services for the new global footer loop
const allServices = await getCollection('services');
allServices.sort((a: any, b: any) => a.data.order - b.data.order);
---

<BaseLayout 
  title={`${entry.data.title} | Fareed M. Rifaideen`} 
  description={entry.data.summary}
>
  <header class="site-header is-scrolled">
    <div class="header-container">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Fareed Logo" />
      </a>
      <nav class="nav-links">
        <a href="/" class="contact-btn glow-breathe" style="background: transparent; color: #fff;">Back to Home</a>
      </nav>
    </div>
  </header>

  <section class="service-hero global-padding">
    <div class="container">
      <div class="label-pill">
        <span class="pill-dot"></span>
        <span>Service Overview</span>
      </div>
      <h1 class="massive-service-title">{entry.data.title}</h1>
      <p class="service-lead">{entry.data.summary}</p>
      
      <div class="tech-tags service-hero-tags">
        {entry.data.techStack && entry.data.techStack.map((tech: string) => (
          <span class="tag">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="service-content global-padding">
    <div class="container content-wrapper">
      <Content />
    </div>
  </section>

  <footer class="site-footer global-padding">
    <div class="container footer-grid">
      
      <div class="footer-col brand-col">
        <img src="/favicon.svg" alt="Fareed Logo" class="footer-logo" />
        <p class="footer-desc">Architecting high-performance digital ecosystems. Focus on ROI and execution.</p>
        <p class="copyright">© {new Date().getFullYear()} Fareed M. Rifaideen.</p>
      </div>

      <div class="footer-col link-col">
        <h4>Capabilities</h4>
        {allServices.map((service: any) => (
          <a href={`/services/${service.id}`}>{service.data.title}</a>
        ))}
        <a href="/projects" class="projects-link">View All Projects ↗</a>
      </div>

      <div class="footer-col link-col">
        <h4>Connect</h4>
        <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://github.com/fareed-rifaideen-ecom" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>

    </div>
  </footer>
</BaseLayout>

<style>
  /* Base Variables */
  :root {
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
  }

  .global-padding { padding: 4rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  /* Header adjustments for sub-pages */
  .site-header.is-scrolled { position: fixed; top: 0; left: 0; width: 100%; padding: 1.5rem 0; z-index: 100; pointer-events: auto; }
  .header-container { max-width: 800px; margin: 0 auto; padding: 0.8rem 1.5rem; display: flex; justify-content: space-between; align-items: center; background: rgba(10, 10, 10, 0.65); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8); }
  .logo img { height: 28px; width: auto; display: block; }
  .contact-btn { font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; padding: 0.5rem 1.2rem; border-radius: 50px; font-size: 0.85rem; transition: all 0.3s ease; text-decoration: none; }
  .contact-btn:hover { background-color: #fff !important; color: #000 !important; }

  /* Hero Section */
  .service-hero { margin-top: 15vh; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 6rem; }
  .massive-service-title { font-family: 'Syne', sans-serif; font-size: clamp(3rem, 5vw, 4.5rem); color: var(--text-primary); margin: 1.5rem 0; line-height: 1.1; letter-spacing: -0.02em; }
  .service-lead { font-family: 'Hanken Grotesk', sans-serif; font-size: 1.2rem; color: var(--text-secondary); max-width: 800px; line-height: 1.7; margin: 0; }
  .label-pill { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 50px; padding: 0.4rem 1.2rem; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; }
  .pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-primary); }
  
  .tech-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag { font-family: 'Hanken Grotesk', sans-serif; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.4rem 0.8rem; border: 1px solid rgba(255, 255, 255, 0.15); color: var(--text-secondary); transition: all 0.3s ease; }
  .service-hero-tags { margin-top: 2.5rem; }

  /* Markdown Content Styling */
  .service-content { padding-top: 6rem; }
  .content-wrapper { max-width: 800px; margin: 0 auto; color: #e0e0e0; font-family: 'Hanken Grotesk', sans-serif; font-size: 1.15rem; line-height: 1.8; }
  
  .content-wrapper :global(h2) { font-family: 'Syne', sans-serif; font-size: 2.2rem; color: #fff; margin-top: 4rem; margin-bottom: 1.5rem; }
  .content-wrapper :global(h3) { font-family: 'Syne', sans-serif; font-size: 1.6rem; color: #f5f5f5; margin-top: 3rem; margin-bottom: 1rem; }
  .content-wrapper :global(p) { margin-bottom: 1.5rem; color: #A3A3A3; }
  .content-wrapper :global(ul) { padding-left: 1.5rem; margin-bottom: 2.5rem; color: #A3A3A3; }
  .content-wrapper :global(li) { margin-bottom: 0.8rem; }
  .content-wrapper :global(strong) { color: #fff; font-weight: 600; }
  .content-wrapper :global(a) { color: #00e5ff; text-decoration: none; border-bottom: 1px solid rgba(0, 229, 255, 0.3); transition: border-color 0.3s ease; }
  .content-wrapper :global(a:hover) { border-color: rgba(0, 229, 255, 1); }

  /* ==========================================
     NEW: STRUCTURED FOOTER NAVIGATION 
  ========================================== */
  .site-footer { border-top: 1px solid #1a1a1a; padding: 4rem 0; background: #000; margin-top: 2rem; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 4rem; align-items: start; }
  
  .footer-col { display: flex; flex-direction: column; gap: 1rem; }
  .footer-logo { height: 35px; width: auto; margin-bottom: 0.5rem; align-self: flex-start; }
  .footer-desc { color: var(--text-secondary); font-size: var(--step-0); line-height: 1.6; max-width: 300px; margin: 0; }
  .copyright { color: #666; font-size: var(--step--1); margin-top: auto; padding-top: 1.5rem; }

  .link-col h4 { font-family: 'Syne', sans-serif; font-size: var(--step-1); color: var(--text-primary); margin: 0 0 0.5rem 0; }
  .link-col a { color: var(--text-secondary); text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-weight: 500; font-size: var(--step-0); transition: color 0.3s ease; }
  .link-col a:hover { color: var(--text-primary); }
  .projects-link { margin-top: 1rem; color: #fff !important; font-weight: 700 !important; }

  @media (max-width: 768px) {
    .header-container { max-width: 90vw; padding: 0.6rem 1.2rem; }
    .service-hero { margin-top: 12vh; padding-bottom: 4rem; }
    .service-content { padding-top: 4rem; }
    .content-wrapper :global(h2) { font-size: 1.8rem; }
    
    /* Footer Mobile Adjustments */
    .footer-grid { grid-template-columns: 1fr; gap: 3rem; text-align: center; }
    .footer-logo { align-self: center; }
    .footer-desc { max-width: 100%; margin: 0 auto; }
    .copyright { padding-top: 0; }
  }
</style>