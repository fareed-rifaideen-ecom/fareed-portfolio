---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch and sort all projects from your existing collection
const allProjects = await getCollection('projects');
allProjects.sort((a: any, b: any) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Featured Work & Projects | Fareed M. Rifaideen" 
  description="Explore a detailed archive of my featured projects, from bespoke WordPress development to data-driven digital marketing campaigns."
>
  <header class="site-header is-scrolled">
    <div class="header-container">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Fareed Logo" />
      </a>
      <nav class="nav-links">
        <a href="/" class="contact-btn glow-breathe" style="background: transparent; color: #fff;">Back to Home</a>
      </nav>
    </div>
  </header>

  <section class="page-hero global-padding">
    <div class="container">
      <div class="label-pill">
        <span class="pill-dot"></span>
        <span>Execution Archive</span>
      </div>
      <h1 class="massive-page-title">Featured<br/>Projects.</h1>
      <p class="page-lead">A deep dive into digital platforms, sales funnels, and ecosystems engineered for growth and scale.</p>
    </div>
  </section>

  <section class="projects-grid-section global-padding">
    <div class="container">
      <div class="projects-grid">
        {allProjects.map((project: any) => (
          <div class="project-card glass-panel">
            
            <div class="project-card-image-wrapper">
              <img src={project.data.image} alt={`${project.data.title} Logo`} class="project-image bw-logo" loading="lazy" />
            </div>

            <div class="project-card-content">
              <h3 class="proj-title">{project.data.title}</h3>
              <p class="proj-summary">{project.data.summary}</p>
              
              <div class="tech-tags">
                {project.data.techStack.map((tech: string) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
              
              <div class="project-actions">
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-solid"><span class="btn-text">View Live Platform</span></a>
              </div>
            </div>

          </div>
        ))}
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-content">
      <p>© {new Date().getFullYear()} Fareed M. Rifaideen.</p>
      <div class="social-links">
        <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  /* Base Variables */
  :root {
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
  }

  .global-padding { padding: 4rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  /* Header adjustments for sub-pages */
  .site-header.is-scrolled { position: fixed; top: 0; left: 0; width: 100%; padding: 1.5rem 0; z-index: 100; pointer-events: auto; }
  .header-container { max-width: 800px; margin: 0 auto; padding: 0.8rem 1.5rem; display: flex; justify-content: space-between; align-items: center; background: rgba(10, 10, 10, 0.65); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8); }
  .logo img { height: 28px; width: auto; display: block; }
  .contact-btn { font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; padding: 0.5rem 1.2rem; border-radius: 50px; font-size: 0.85rem; transition: all 0.3s ease; text-decoration: none; }
  .contact-btn:hover { background-color: #fff !important; color: #000 !important; }

  /* Hero Section */
  .page-hero { margin-top: 15vh; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 4rem; }
  .massive-page-title { font-family: 'Syne', sans-serif; font-size: clamp(3rem, 6vw, 5.5rem); color: var(--text-primary); margin: 1.5rem 0; line-height: 1.1; letter-spacing: -0.02em; }
  .page-lead { font-family: 'Hanken Grotesk', sans-serif; font-size: 1.2rem; color: var(--text-secondary); max-width: 800px; line-height: 1.7; margin: 0; }
  .label-pill { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid rgba(255,255,255,0.2); border-radius: 50px; padding: 0.4rem 1.2rem; font-size: 0.85rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; }
  .pill-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--text-primary); }
  
  /* Projects Grid */
  .projects-grid-section { padding-top: 4rem; }
  .projects-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 3rem; }
  
  .glass-panel { background: linear-gradient(135deg, rgba(25, 25, 25, 0.4) 0%, rgba(10, 10, 10, 0.8) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255, 255, 255, 0.1); border-left: 1px solid rgba(255, 255, 255, 0.1); border-bottom: 1px solid rgba(255, 255, 255, 0.02); border-right: 1px solid rgba(255, 255, 255, 0.02); box-shadow: 0 15px 35px rgba(0, 0, 0, 0.8); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; }

  .project-card-image-wrapper { height: 250px; display: flex; align-items: center; justify-content: center; background: rgba(5, 5, 5, 0.5); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 2rem; }
  .project-image { max-width: 80%; max-height: 120px; object-fit: contain; }
  .bw-logo { filter: grayscale(100%) brightness(1.5); transition: all 0.4s ease; opacity: 0.8; }
  .project-card:hover .bw-logo { filter: grayscale(0) brightness(1); opacity: 1; transform: scale(1.05); }

  .project-card-content { padding: 3rem; display: flex; flex-direction: column; flex-grow: 1; }
  .proj-title { font-family: 'Syne', sans-serif; font-size: 2rem; color: var(--text-primary); margin: 0 0 1rem 0; line-height: 1.2; }
  .proj-summary { font-size: 1.05rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 2rem; }
  
  .tech-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 3rem; }
  .tag { font-family: 'Hanken Grotesk', sans-serif; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.4rem 0.8rem; border: 1px solid rgba(255, 255, 255, 0.15); color: var(--text-secondary); transition: all 0.3s ease; border-radius: 50px; }
  .tag:hover { border-color: var(--text-primary); color: var(--text-primary); }

  .project-actions { margin-top: auto; padding-top: 1rem; }
  
  /* Buttons */
  .btn-solid { position: relative; overflow: hidden; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; background: #fff; color: #000; padding: 0.8rem 2rem; border-radius: 50px; text-decoration: none; border: 1px solid #fff; display: inline-flex; align-items: center; justify-content: center; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); width: 100%; }
  .btn-solid .btn-text { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 2; position: relative; }
  .btn-solid::after { content: '↗'; position: absolute; right: 1.2rem; opacity: 0; transform: translate(-10px, 10px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 2; font-weight: 800; }
  .btn-solid:hover { background: transparent; color: #fff; padding-right: 3rem; padding-left: 1rem; }
  .btn-solid:hover .btn-text { transform: translateX(-5px); }
  .btn-solid:hover::after { opacity: 1; transform: translate(0, 0); }
  .btn-solid::before { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(to right, rgba(0,0,0,0) 0%, rgba(0,0,0,0.15) 50%, rgba(0,0,0,0) 100%); transform: skewX(-25deg); animation: liquid-sheen 4s infinite cubic-bezier(0.16, 1, 0.3, 1); z-index: 1; }
  .btn-solid:hover::before { display: none; }
  
  @keyframes liquid-sheen { 0% { left: -100%; } 20% { left: 200%; } 100% { left: 200%; } }

  /* Footer */
  .site-footer { border-top: 1px solid #1a1a1a; padding: 3rem 0; margin-top: 4rem; }
  .footer-content { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
  .footer-content p { color: var(--text-secondary); font-size: 1rem; margin: 0; font-family: 'Hanken Grotesk', sans-serif; }
  .social-links { display: flex; gap: 2rem; }
  .social-links a { color: var(--text-primary); text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; transition: color 0.3s ease; }
  .social-links a:hover { color: var(--text-secondary); }

  @media (max-width: 768px) {
    .header-container { max-width: 90vw; padding: 0.6rem 1.2rem; }
    .page-hero { margin-top: 12vh; padding-bottom: 3rem; }
    .projects-grid { grid-template-columns: 1fr; gap: 2rem; }
    .project-card-content { padding: 2rem; }
    .proj-title { font-size: 1.5rem; }
    .footer-content { flex-direction: column; text-align: center; }
  }
</style>