---
// src/pages/resources/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Resources | Compiling Databank | Fareed M. Rifaideen" 
  description="Technical SEO workflows, digital marketing SOPs, and custom web development execution logs. Launching soon."
>
  <!-- Animated Cyber Grid Background -->
  <div class="cyber-grid"></div>
  <div class="grid-fade-overlay"></div>

  <!-- Minimal Header -->
  <header class="site-header is-scrolled">
    <div class="header-container">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Fareed Logo" />
      </a>
      <nav class="nav-links">
        <a href="/" class="contact-btn" style="background: transparent; color: #fff;">Return to Base</a>
      </nav>
    </div>
  </header>

  <!-- Coming Soon Interactive Terminal -->
  <section class="launching-soon-section">
    <div class="container launch-container">
      
      <div class="glass-vault">
        
        <!-- Pulsing Status Indicator -->
        <div class="status-wrapper">
          <div class="status-dot"></div>
          <span class="status-text">Server Status: Compiling</span>
        </div>

        <!-- GSAP Text Scramble Target -->
        <h1 class="massive-launch-title" id="decrypt-text">Initializing...</h1>
        
        <p class="launch-desc">
          Standard Operating Procedures (SOPs), technical SEO frameworks, and GitHub deployment logs are currently being formatted for public release. 
        </p>

        <div class="launch-actions">
          <a href="/" class="btn-solid glow-breathe"><span class="btn-text">Return to Main Portfolio</span></a>
        </div>

        <!-- Terminal Progress Bar -->
        <div class="terminal-progress">
          <div class="progress-info">
            <span>> building_knowledge_base.sh</span>
            <span class="progress-percentage">73%</span>
          </div>
          <div class="progress-track">
            <div class="progress-fill"></div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <script>
    import gsap from 'gsap';
    import { TextPlugin } from 'gsap/TextPlugin';

    gsap.registerPlugin(TextPlugin);

    // Dynamic Text Scramble / Typewriter Effect
    const decryptText = document.getElementById("decrypt-text");
    
    if (decryptText) {
      let tl = gsap.timeline({ repeat: -1, repeatDelay: 4 });
      
      tl.to(decryptText, { 
        duration: 1.5, 
        text: "Compiling Databank.", 
        ease: "none", 
        delay: 0.5 
      })
      .to(decryptText, { 
        duration: 1.5, 
        text: "Encrypting SOPs.", 
        ease: "none", 
        delay: 3 
      })
      .to(decryptText, { 
        duration: 1.5, 
        text: "Deployment Pending.", 
        ease: "none", 
        delay: 3 
      });
    }

    // Vault floating animation
    gsap.to(".glass-vault", {
      y: -15,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  </script>
</BaseLayout>

<style>
  :root {
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
  }

  /* --- Background Cyber Grid Animation --- */
  .cyber-grid {
    position: fixed;
    top: 0; left: 0; width: 100vw; height: 150vh;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: 0;
    animation: panGrid 20s linear infinite;
  }
  
  .grid-fade-overlay {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    background: radial-gradient(circle at center, transparent 0%, #050505 80%);
    z-index: 1; pointer-events: none;
  }

  @keyframes panGrid {
    0% { transform: translateY(0); }
    100% { transform: translateY(-50px); }
  }

  /* --- Header --- */
  .site-header.is-scrolled { position: fixed; top: 0; left: 0; width: 100%; padding: 1.5rem 0; z-index: 100; pointer-events: auto; }
  .header-container { max-width: 800px; margin: 0 auto; padding: 0.8rem 1.5rem; display: flex; justify-content: space-between; align-items: center; background: rgba(10, 10, 10, 0.65); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 50px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.8); }
  .logo img { height: 28px; width: auto; display: block; }
  .contact-btn { font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; padding: 0.5rem 1.2rem; border-radius: 50px; font-size: 0.85rem; transition: all 0.3s ease; text-decoration: none; }
  .contact-btn:hover { background-color: #fff !important; color: #000 !important; }

  /* --- Launching Soon Section --- */
  .launching-soon-section { height: 100vh; width: 100vw; display: flex; align-items: center; justify-content: center; position: relative; z-index: 2; overflow: hidden; }
  .launch-container { width: 100%; display: flex; justify-content: center; padding: 0 2rem; }

  .glass-vault {
    background: linear-gradient(135deg, rgba(25, 25, 25, 0.6) 0%, rgba(10, 10, 10, 0.9) 100%);
    backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.9), inset 0 1px 0 rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 5rem 4rem;
    max-width: 700px;
    width: 100%;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .status-wrapper { display: flex; align-items: center; gap: 0.8rem; margin-bottom: 2rem; }
  .status-dot { width: 10px; height: 10px; background-color: #ffbd2e; border-radius: 50%; box-shadow: 0 0 10px #ffbd2e; animation: pulse-status 1.5s infinite alternate; }
  .status-text { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 0.85rem; color: #ffbd2e; text-transform: uppercase; letter-spacing: 0.1em; }

  @keyframes pulse-status {
    0% { opacity: 0.4; box-shadow: 0 0 5px #ffbd2e; }
    100% { opacity: 1; box-shadow: 0 0 15px #ffbd2e; }
  }

  .massive-launch-title { font-family: 'Syne', sans-serif; font-size: clamp(2.5rem, 5vw, 4rem); color: var(--text-primary); margin: 0 0 1.5rem 0; line-height: 1.1; letter-spacing: -0.02em; min-height: 4.5rem; /* Prevents layout shift during GSAP typing */ }
  .launch-desc { font-family: 'Hanken Grotesk', sans-serif; font-size: 1.1rem; color: var(--text-secondary); line-height: 1.7; margin-bottom: 3rem; max-width: 550px; }

  /* Buttons */
  .btn-solid { position: relative; overflow: hidden; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; background: #fff; color: #000; padding: 1rem 2.5rem; border-radius: 50px; text-decoration: none; border: 1px solid #fff; display: inline-flex; align-items: center; justify-content: center; transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); }
  .btn-solid .btn-text { transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 2; position: relative; }
  .btn-solid::after { content: '↗'; position: absolute; right: 1.2rem; opacity: 0; transform: translate(-10px, 10px); transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1); z-index: 2; font-weight: 800; }
  .btn-solid:hover { background: transparent; color: #fff; padding-right: 3.2rem; padding-left: 1.8rem; }
  .btn-solid:hover .btn-text { transform: translateX(-5px); }
  .btn-solid:hover::after { opacity: 1; transform: translate(0, 0); }

  .glow-breathe { animation: neon-breathe 4s infinite ease-in-out; }
  @keyframes neon-breathe { 0%, 100% { box-shadow: 0 0 0 rgba(255, 255, 255, 0); } 50% { box-shadow: 0 0 20px rgba(255, 255, 255, 0.2), 0 0 8px rgba(255, 255, 255, 0.1); } }

  /* Progress Bar Terminal effect */
  .terminal-progress { margin-top: 4rem; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
  .progress-info { display: flex; justify-content: space-between; font-family: ui-monospace, SFMono-Regular, monospace; font-size: 0.8rem; color: #A3A3A3; margin-bottom: 0.8rem; }
  .progress-percentage { color: #27c93f; font-weight: 600; }
  
  .progress-track { width: 100%; height: 4px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; position: relative; }
  .progress-fill { position: absolute; top: 0; left: 0; height: 100%; width: 73%; background: #27c93f; border-radius: 4px; box-shadow: 0 0 10px #27c93f; animation: loading-shimmer 2s infinite linear; }

  @media (max-width: 768px) {
    .header-container { max-width: 90vw; padding: 0.6rem 1.2rem; }
    .glass-vault { padding: 3rem 2rem; }
    .massive-launch-title { min-height: 6rem; } /* Gives mobile more room for text wrapping */
  }
</style>