---
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/600.css';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg'; 

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer</title>
    <meta name="title" content="Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer" />
    <meta name="description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />
    <meta name="author" content="Fareed M. Rifaideen" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fareed-rifaideen.netlify.app/" />
    <meta property="og:title" content="Fareed M. Rifaideen | Portfolio" />
    <meta property="og:description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />
    
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://fareed-rifaideen.netlify.app/" />
    <meta property="twitter:title" content="Fareed M. Rifaideen | Portfolio" />
    <meta property="twitter:description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />

    <link rel="canonical" href="https://fareed-rifaideen.netlify.app/" />
  </head>
  <body>
    
    <header class="site-header">
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.svg" alt="Fareed M. Rifaideen Logo" />
        </a>
        <nav class="nav-links">
          <a href="https://wa.me/9717775962" class="contact-btn" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="mailto:fareed.rifaideen@gmail.com" class="contact-btn">Let's Talk</a>
        </nav>
      </div>
    </header>

    <section class="cinematic-hero">
      <div class="cinematic-container">
        
        <div class="intro-text">
          <h1>Fareed M.<br/>Rifaideen</h1>
          <h2>Full-Stack Digital Marketer & Web Developer</h2>
        </div>

        <div class="scroll-icon-wrapper">
          <img src="/scroll-icon.svg" alt="Scroll Down" class="scroll-icon" />
        </div>

        <div class="portrait-wrapper">
          <Image src={profileImg} alt="Fareed Profile" class="portrait-img" /> 
        </div>

        <div class="bio-text">
          <p class="bio">
            Drawing on a foundational background in financial operations and resource allocation, I engineer digital marketing strategies that are both technically robust and highly cost-effective.
          </p>
          <p class="bio">
            As a Certified Digital Marketing Professional (CDMP), I specialize in the intersection of technical SEO, bespoke WordPress and WooCommerce development, and precision Meta Ads.
          </p>
        </div>

      </div>
    </section>

    <section class="projects-section">
      <div class="container">
        <h2 class="section-title">Featured Projects</h2>
        
        <div class="projects-grid">
          {allProjects.map((project) => (
            <div class="project-card">
              <h3>{project.data.title}</h3>
              <p>{project.data.summary}</p>
              
              <div class="tech-tags">
                {project.data.techStack.map((tech) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-content">
        <p>© {new Date().getFullYear()} Fareed M. Rifaideen. All rights reserved.</p>
        <div class="social-links">
          <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/fareed-rifaideen-ecom" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from '@studio-freight/lenis';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      let mm = gsap.matchMedia();

      // Desktop Cinematic Animation
      mm.add("(min-width: 768px)", () => {
        let tl = gsap.timeline({
          scrollTrigger: {
            trigger: ".cinematic-hero",
            pin: true,
            scrub: 1.5, 
            start: "top top",
            end: "+=300%" 
          }
        });

        // Act 1 to 2: Fade out text/icon, Center the face
        tl.to(".intro-text", { opacity: 0, x: -50, duration: 1 }, 0)
          .to(".scroll-icon-wrapper", { opacity: 0, y: 20, duration: 0.5 }, 0)
          .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);

        // Act 2 to 3: Move face left, fade in Bio
        tl.to(".portrait-wrapper", { x: "-25vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
          .to(".bio-text", { opacity: 1, x: 0, duration: 1, ease: "power1.out" }, 1.5);
      });

      // Mobile Cinematic Animation 
      mm.add("(max-width: 767px)", () => {
        let mobileTl = gsap.timeline({
          scrollTrigger: {
            trigger: ".cinematic-hero",
            pin: true,
            scrub: 1.5,
            start: "top top",
            end: "+=250%" 
          }
        });

        // Act 1 to 2: Fade out text/icon, Center face
        mobileTl.to(".intro-text", { opacity: 0, y: 30, duration: 1 }, 0)
          .to(".scroll-icon-wrapper", { opacity: 0, duration: 0.5 }, 0)
          .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);

        // Act 2 to 3: Move face left (keeping full brightness), fade in right-aligned Bio
        mobileTl.to(".portrait-wrapper", { x: "-35vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
          .to(".bio-text", { opacity: 1, y: 0, duration: 1, ease: "power1.out" }, 1.5);
      });

      // Project Cards Cascade Animation 
      gsap.from(".project-card", {
        opacity: 0,
        y: 40,
        stagger: 0.2, 
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: ".projects-grid",
          start: "top 85%",
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #050505;
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: 'Hanken Grotesk', sans-serif;
    margin: 0;
    overflow-x: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .site-header {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 2rem 0;
    z-index: 100;
    mix-blend-mode: difference;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo img {
    height: 35px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .contact-btn {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid #fff;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .contact-btn:hover {
    background-color: #fff;
    color: #000;
  }

  /* Cinematic Unified Section */
  .cinematic-hero {
    height: 100vh;
    width: 100vw;
    background-color: var(--bg-color);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cinematic-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    height: 100%;
    margin: 0 auto;
    display: flex;
    align-items: center;
  }

  /* Act 1: Intro Text */
  .intro-text {
    position: absolute;
    left: 2rem;
    z-index: 10;
  }

  .intro-text h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 7vw, 6.5rem);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }

  .intro-text h2 {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.5rem);
    color: var(--text-secondary);
    margin-top: 1rem;
  }

  /* Scroll Icon */
  .scroll-icon-wrapper {
    position: absolute;
    bottom: 3rem;
    left: 2rem; 
    z-index: 10;
  }

  .scroll-icon {
    width: 30px;
    height: auto;
    opacity: 0.7;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-10px); }
    60% { transform: translateY(-5px); }
  }

  /* Act 2: Portrait */
  .portrait-wrapper {
    position: absolute;
    height: 100vh;
    width: 100vw;
    top: 0;
    left: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    transform: translateX(35vw);
  }

  .portrait-img {
    height: 100%;
    width: 100%;
    max-width: 800px;
    object-fit: cover;
    object-position: center;
  }

  /* Act 3: Bio Text */
  .bio-text {
    position: absolute;
    right: 2rem;
    width: 450px;
    z-index: 10;
    opacity: 0; 
    transform: translateX(50px); 
  }

  .bio {
    color: var(--text-secondary);
    font-size: 1.2rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  /* Projects */
  .projects-section {
    padding: 10rem 0 5rem 0;
    background-color: var(--bg-color);
    position: relative;
    z-index: 20; 
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    margin-bottom: 4rem;
    color: var(--text-primary);
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .project-card {
    border-top: 1px solid #333;
    padding-top: 2rem;
  }

  .project-card h3 {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }

  .project-card p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 800px;
    margin: 0;
  }

  .tech-tags {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 1rem;
    border: 1px solid #333;
    color: var(--text-secondary);
    transition: all 0.3s ease;
  }

  .tag:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  /* Footer */
  .site-footer {
    border-top: 1px solid #1a1a1a;
    padding: 3rem 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-content p {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .social-links a {
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--text-secondary);
  }

  /* Mobile Layout Adjustments */
  @media (max-width: 768px) {
    .nav-links {
      gap: 0.5rem;
    }

    .contact-btn {
      padding: 0.5rem 1rem;
      font-size: 0.75rem;
    }

    .intro-text {
      bottom: 15%;
      left: 1.5rem;
    }
    
    .intro-text h1 {
      font-size: clamp(2.5rem, 12vw, 4rem); 
    }

    .intro-text h2 {
      font-size: 0.9rem;
    }

    .scroll-icon-wrapper {
      left: 50%;
      transform: translateX(-50%);
      bottom: 3%;
    }
    
    @keyframes bounce {
      0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); }
      40% { transform: translate(-50%, -10px); }
      60% { transform: translate(-50%, -5px); }
    }

    .portrait-wrapper {
      transform: translateX(35vw); 
    }

    .bio-text {
      width: 75%;
      right: 1.5rem;
      left: auto;
      text-align: right; 
      transform: translateY(30px); 
    }
    
    .bio {
      font-size: 1rem;
      line-height: 1.5;
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>