---
// src/pages/index.astro
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg'; 
import ethosImg from '../assets/ethos-portrait.jpg';
import BaseLayout from '../layouts/BaseLayout.astro';

// INJECTED COMPONENTS
import GlobalHeader from '../components/GlobalHeader.astro';
import GlobalFooter from '../components/GlobalFooter.astro';
import ContactModal from '../components/ContactModal.astro';

import 'swiper/css';
import 'swiper/css/pagination';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
const carouselProjects = allProjects;

const allExperience = await getCollection('experience');
allExperience.sort((a, b) => a.data.order - b.data.order);

const allEducation = await getCollection('education');
allEducation.sort((a, b) => a.data.order - b.data.order);

const ethosEntries = await getCollection('ethos');
const ethosData = ethosEntries[0];
const { Content: EthosContent } = await render(ethosData);

let fetchedServices: any[] = [];
try {
  fetchedServices = await getCollection('services');
} catch (e) {
  console.warn("Services collection missing or error. Using fallback.");
}

const fallbackServices = [
  { id: "full-stack-seo", data: { title: "Full-Stack SEO", command: "execute_seo", summary: "I align your digital infrastructure with exactly what search engines demand and what your target market is actively looking for. From server-side technical health to frontend semantic structure, I eliminate roadblocks to drive high-intent, organic traffic directly to your storefront.", order: 1 } },
  { id: "data-driven-marketing", data: { title: "Data-Driven Marketing", command: "execute_marketing", summary: "Paid media requires strict financial discipline. I design and manage highly targeted campaigns across Meta and Google, leveraging real-time analytics to immediately cut wasted spend and aggressively scale the strategies that generate verified returns.", order: 2 } },
  { id: "custom-web-development", data: { title: "Custom Web Development", command: "execute_development", summary: "Off-the-shelf templates rarely scale. I build custom, lightning-fast WordPress and WooCommerce platforms tailored specifically to your sales funnels. I focus on clean PHP backend development and intuitive UI design to ensure a completely frictionless experience from the landing page to the checkout.", order: 3 } }
];

let allServices: any[] = (fetchedServices && fetchedServices.length > 0) ? fetchedServices : fallbackServices;
allServices.sort((a: any, b: any) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer"
  description="Architecting high-performance digital ecosystems. Specializing in comprehensive SEO, bespoke WordPress development, and precision Full-Stack Digital Marketing strategies."
>
    
  <Image src={profileImg} alt="" class="ghost-watermark" id="bg-portrait" loading="lazy" />

  <GlobalHeader />

  <section class="cinematic-hero">
    <div class="cinematic-container">
      <div class="intro-text">
        <h1 class="sr-only">Fareed M. Rifaideen - Full-Stack Digital Marketer & Web Developer in Dubai</h1>
        
        <span class="hero-title" aria-hidden="true">Fareed M.<br/>Rifaideen</span>
        
        <h2 class="dynamic-subtitle-wrapper">I'm a <span class="dynamic-subtitle">Full-Stack Digital Marketer & Web Developer</span></h2>
      </div>
      
      <div class="scroll-icon-wrapper">
        <div class="magnetic-target">
          <span class="magnetic-text">Scroll</span>
          <div class="icon-bounce-wrapper">
            <img src="/scroll-Icon.svg" alt="Scroll Down" class="scroll-icon" />
          </div>
        </div>
      </div>

      <div class="portrait-wrapper">
        <Image src={profileImg} alt="Fareed Profile" class="portrait-img hero-portrait" loading="eager" /> 
      </div>
      <div class="bio-text">
        <p class="bio">
          I build digital ecosystems engineered for one specific metric: ROI. With a decade of experience in financial operations, I treat your marketing budget as a direct investment rather than an operational expense.
        </p>
        <p class="bio">
          As a Full-Stack Marketer and Web Developer, I bridge the gap between technical infrastructure and customer acquisition. From custom WooCommerce platforms to rigorous technical SEO, I design digital spaces that solve complex problems and drive tangible revenue.
        </p>
        <a href="#ethos" class="btn-outline bio-cta">Read My Ethos <span class="bounce-arrow">↓</span></a>
      </div>
    </div>
  </section>

  <section class="services-sticky-section global-padding" id="services">
    <div class="container">
      <div class="sticky-editorial-layout">
        
        <div class="sticky-sidebar">
          <div class="sticky-content">
            <h2 class="section-title">What I Do</h2>
            <p class="sticky-description">
              I engineer digital growth by combining technical architecture with highly targeted acquisition strategies. Here is exactly how I turn execution into tangible business revenue.
            </p>
            <a href="#contact-modal" class="btn-solid modal-trigger sticky-cta glow-breathe"><span class="btn-text">Start a Project</span></a>
          </div>
        </div>

        <div class="scrolling-cards-container">
          {allServices.map((service: any, index: number) => (
            <div class="editorial-service-card glass-panel service-anim-card">
              <div class="service-card-header">
                <span class="service-number">0{index + 1}</span>
                <h3 class="service-title">{service.data.title}</h3>
              </div>
              <div class="service-card-body">
                <div class="service-card-body-inner">
                  <p class="service-pitch">{service.data.summary}</p>
                  <a href={`/services/${service.id}`} class="service-read-more">Explore Capability <span class="arrow">↗</span></a>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <section class="projects-flip-track-section global-padding" id="projects">
    <div class="container">
      <div class="projects-header-wrapper">
        <div class="label-pill">
          <span class="pill-dot"></span>
          <span>Featured Work</span>
        </div>
        <h2 class="massive-projects-title">Engineered for<br/>Growth & Scale.</h2>
      </div>
    </div>

    <div class="swiper flip-projects-swiper">
      <div class="swiper-wrapper">
        {carouselProjects.map((project: any) => (
          <div class="swiper-slide flip-project-card">
            <div class="flip-card-inner">
              
              <div class="flip-card-front glass-panel">
                <h3 class="proj-front-title">{project.data.title}</h3>
                <p class="proj-front-summary">{project.data.summary}</p>
                <div class="tech-tags">
                  {project.data.techStack.slice(0, 3).map((tech: string) => (
                    <span class="tag pill-tag">{tech}</span>
                  ))}
                </div>
              </div>

              <div class="flip-card-back glass-panel" aria-hidden="true">
                <img src={project.data.image} alt={`${project.data.title} Logo`} class="project-logo bw-logo" loading="lazy" decoding="async" />
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-solid view-project-btn"><span class="btn-text">View Live Project</span></a>
              </div>

            </div>
          </div>
        ))}
      </div>
      <div class="swiper-pagination flip-pagination"></div>
    </div>
  </section>

  <section class="terminal-experience-section global-padding" id="experience">
    <div class="container">
      <div class="projects-header-wrapper">
        <div class="label-pill">
          <span class="pill-dot"></span>
          <span>Career History</span>
        </div>
        <h2 class="massive-projects-title">Execution Logs.</h2>
      </div>

      <div class="terminal-window">
        
        <div class="terminal-header">
          <div class="terminal-buttons">
            <span class="term-btn red"></span>
            <span class="term-btn yellow"></span>
            <span class="term-btn green"></span>
          </div>
          <div class="terminal-title">fareed@admin: ~/career/logs</div>
        </div>

        <div class="terminal-body desktop-terminal">
          <div class="terminal-sidebar">
            <p class="term-comment"># Hover to execute deployment log:</p>
            {allExperience.map((job: any, index: number) => {
              const safeTitle = job.data.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();
              return (
                <button 
                  class="term-command desktop-cmd" 
                  data-date={job.data.date}
                  data-title={job.data.title}
                  data-company={job.data.company}
                  data-problem={job.data.problemStatement}
                >
                  <span class="prompt-arrow">❯</span> ./run_{safeTitle}
                </button>
              );
            })}
          </div>
          
          <div class="terminal-main">
            <div class="terminal-output-wrapper">
              <div id="desktop-terminal-output" class="terminal-output">
                <p class="system-msg term-comment">System ready. Awaiting command input...</p>
              </div>
              <span class="blinking-cursor">█</span>
            </div>
          </div>
        </div>

        <div class="terminal-body mobile-terminal">
          <p class="term-comment"># Tap to execute deployment log:</p>
          {allExperience.map((job: any, index: number) => {
            const safeTitle = job.data.title.replace(/[^a-zA-Z0-9]/g, '_').toLowerCase();
            return (
              <div class="mobile-term-group">
                <button 
                  class="term-command mobile-cmd" 
                  data-index={index}
                  data-date={job.data.date}
                  data-title={job.data.title}
                  data-company={job.data.company}
                  data-problem={job.data.problemStatement}
                >
                  <span class="prompt-arrow">❯</span> ./run_{safeTitle}
                </button>
                <div class="mobile-output-wrapper" id={`mobile-output-${index}`}>
                  <div class="mobile-output-content"></div>
                  <span class="blinking-cursor mobile-cursor" style="display:none;">█</span>
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <div id="global-tooltip" class="glass-panel hidden-tooltip">
    <p id="tooltip-text"></p>
  </div>

  <section class="bento-section global-padding">
    <div class="container">
      <h2 class="section-title">Arsenal & Education</h2>
      <div class="bento-grid">
        <div class="bento-card skills-card">
          <h3>Technical Stack</h3>
          <div class="tech-tags">
            <span class="tag">Digital Strategy</span>
            <span class="tag">Technical SEO</span>
            <span class="tag">Meta Ads & PPC</span>
            <span class="tag">Google Ads & SEM</span>
            <span class="tag">Data Analytics (GA4)</span>
            <span class="tag">WordPress & WooCommerce</span>
            <span class="tag">PHP</span>
            <span class="tag">E-commerce Optimization</span>
            <span class="tag">AI-Driven Trend Analysis</span>
            <span class="tag">Campaign Performance Monitoring</span>
          </div>
        </div>

        <div class="bento-card cert-card">
          <h3>Professional Memberships</h3>
          <p>Member of Chartered Management Institute (MCMI)</p>
          <span class="bento-meta">CMI, UK</span>
        </div>

        {allEducation.map((edu: any) => (
          <div class="bento-card edu-card">
            <h3>{edu.data.degree}</h3>
            <p>{edu.data.institution}</p>
            <span class="bento-meta">{edu.data.date}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ethos-section global-padding" id="ethos">
    <div class="container">
      <div class="ethos-split-layout">
        
        <div class="ethos-box">
          <h2>{ethosData.data.title}</h2>
          <div class="ethos-content">
            <EthosContent />
            <a href={ethosData.data.buttonLink} class="contact-btn ethos-btn modal-trigger">{ethosData.data.buttonText}</a>
          </div>
        </div>

        <div class="ethos-image-wrapper glass-panel" id="ethos-interact-zone">
          <Image src={ethosImg} alt="Ethos Portrait" class="ethos-base-img" loading="lazy" />
          <div class="ethos-color-layer" id="ethos-color-reveal">
            <Image src={ethosImg} alt="" class="ethos-reveal-img" loading="lazy" />
          </div>
          <div class="haptic-prompt" id="haptic-hint">
            <div class="haptic-ring"></div>
            <svg class="fingerprint-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm2-8.5c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-4.5 3c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zm9 0c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

      </div>
    </div>
  </section>

  <GlobalFooter />
  <ContactModal />

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { TextPlugin } from 'gsap/TextPlugin';
    import Lenis from '@studio-freight/lenis';
    import Swiper from 'swiper';
    import { Pagination, Autoplay } from 'swiper/modules';

    gsap.registerPlugin(ScrollTrigger, TextPlugin);

    // --- Smooth Scrolling ---
    const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
    (window as any).lenis = lenis; // Exposed so ContactModal can pause the scroll
    function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // --- Magnetic Scroll Indicator Logic (Desktop Only) ---
    const magTarget = document.querySelector('.magnetic-target');
    const heroSection = document.querySelector('.cinematic-hero');
    
    if (magTarget && heroSection && window.innerWidth > 768) {
      heroSection.addEventListener('mousemove', (e) => {
        const mouseEvent = e as MouseEvent;
        const wrapper = magTarget.parentElement as HTMLElement;
        const rect = wrapper.getBoundingClientRect();
        
        const centerX = rect.left + rect.width / 2;
        const centerY = rect.top + rect.height / 2;
        
        const distX = mouseEvent.clientX - centerX;
        const distY = mouseEvent.clientY - centerY;
        const distance = Math.sqrt(distX * distX + distY * distY);
        
        if (distance < 600) {
          gsap.to(magTarget, { x: distX * 0.3, y: distY * 0.3, rotate: distX * 0.05, duration: 0.4, ease: "power2.out" });
        } else {
          gsap.to(magTarget, { x: 0, y: 0, rotate: 0, duration: 0.8, ease: "elastic.out(1, 0.4)" });
        }
      });
      
      heroSection.addEventListener('mouseleave', () => {
        gsap.to(magTarget, { x: 0, y: 0, rotate: 0, duration: 0.8, ease: "elastic.out(1, 0.4)" });
      });
    }

    // --- Lenis Anchor Interceptor ---
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        const targetId = anchor.getAttribute('href');
        if (targetId && targetId !== '#contact-modal' && targetId !== '#') {
          e.preventDefault();
          lenis.scrollTo(targetId, { duration: 1.5, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
        }
      });
    });

    // --- Ghost Watermark Background Fade ---
    gsap.to("#bg-portrait", {
      opacity: 0.03, scrollTrigger: { trigger: ".services-sticky-section", start: "top 80%", end: "top 20%", scrub: true }
    });

    // --- 3D Flip Track Carousel Logic ---
    new Swiper('.flip-projects-swiper', {
      modules: [Pagination, Autoplay], slidesPerView: 'auto', centeredSlides: true, spaceBetween: 80, loop: true, speed: 1000, 
      autoplay: { delay: 3000, disableOnInteraction: false, pauseOnMouseEnter: true },
      pagination: { el: '.flip-pagination', clickable: true }
    });

    const flipCards = document.querySelectorAll('.flip-project-card');
    flipCards.forEach(card => {
      card.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          card.classList.toggle('is-flipped');
          flipCards.forEach(otherCard => {
            if (otherCard !== card) otherCard.classList.remove('is-flipped');
          });
        }
      });
    });

    // ==========================================
    // --- ETHOS X-RAY / INK DROP ENGINE ---
    // ==========================================
    const ethosZone = document.getElementById('ethos-interact-zone');
    const colorReveal = document.getElementById('ethos-color-reveal');
    const hapticHint = document.getElementById('haptic-hint');
    let hintDismissed = false;

    if (ethosZone && colorReveal) {
      ethosZone.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        if (window.innerWidth > 768) {
          if (!hintDismissed && hapticHint) {
            gsap.to(hapticHint, { opacity: 0, duration: 0.5, onComplete: () => hapticHint.style.display = 'none' });
            hintDismissed = true;
          }
          const rect = ethosZone.getBoundingClientRect();
          const x = mouseEvent.clientX - rect.left;
          const y = mouseEvent.clientY - rect.top;
          gsap.to(colorReveal, { '--x': `${x}px`, '--y': `${y}px`, '--size': '150px', duration: 0.3, ease: "power2.out" });
        }
      });

      ethosZone.addEventListener('mouseleave', () => {
        if (window.innerWidth > 768) {
          gsap.to(colorReveal, { '--size': '0px', duration: 0.5, ease: "power2.out" });
        }
      });

      let isTouching = false;
      const triggerInkDrop = (e: Event) => {
        const touchEvent = e as TouchEvent;
        if (window.innerWidth <= 768) {
          if (e.cancelable) e.preventDefault(); 
          isTouching = true;
          if (!hintDismissed && hapticHint) {
            gsap.to(hapticHint, { opacity: 0, duration: 0.5, onComplete: () => hapticHint.style.display = 'none' });
            hintDismissed = true;
          }
          const rect = ethosZone.getBoundingClientRect();
          const touch = touchEvent.touches[0];
          const x = touch.clientX - rect.left;
          const y = touch.clientY - rect.top;
          gsap.set(colorReveal, { '--x': `${x}px`, '--y': `${y}px`, '--size': '0px' });
          gsap.to(colorReveal, { '--size': '1200px', duration: 1.2, ease: "power2.inOut" });
        }
      };

      const reverseInkDrop = () => {
        if (window.innerWidth <= 768 && isTouching) {
          isTouching = false;
          gsap.to(colorReveal, { '--size': '0px', duration: 0.5, ease: "power2.in" });
        }
      };

      ethosZone.addEventListener('touchstart', triggerInkDrop, { passive: false });
      ethosZone.addEventListener('touchend', reverseInkDrop);
      ethosZone.addEventListener('touchcancel', reverseInkDrop);
    }

    let mm = gsap.matchMedia();

    // ==========================================
    // --- DESKTOP GSAP LOGIC ---
    // ==========================================
    mm.add("(min-width: 768px)", () => {
      let tl = gsap.timeline({ scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=300%" } });
      tl.to(".intro-text", { opacity: 0, x: -50, duration: 1 }, 0)
        .to(".scroll-icon-wrapper", { opacity: 0, y: 20, duration: 0.5 }, 0)
        .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);
      tl.to(".portrait-wrapper", { x: "-25vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
        .to(".bio-text", { opacity: 1, x: 0, duration: 1, ease: "power1.out" }, 1.5);
      tl.to({}, { duration: 1.5 });

      ScrollTrigger.create({ trigger: ".services-sticky-section", start: 'top 15%', end: 'max', toggleClass: { className: 'is-scrolled', targets: '.site-header' } });

      const desktopCmds = document.querySelectorAll('.desktop-cmd');
      const desktopOutput = document.getElementById('desktop-terminal-output');

      desktopCmds.forEach(cmd => {
        cmd.addEventListener('mouseenter', () => {
          const el = cmd as HTMLElement;
          desktopCmds.forEach(c => c.classList.remove('active-cmd'));
          el.classList.add('active-cmd');

          const date = el.getAttribute('data-date');
          const title = el.getAttribute('data-title');
          const company = el.getAttribute('data-company');
          const problem = el.getAttribute('data-problem');

          const logHTML = `
            <span class="term-date">[ ${date} ]</span><br/>
            <span class="term-process">TARGET_ORG:</span> <span class="term-title">${company}</span><br/>
            <span class="term-process">EXEC_ROLE:</span> <span class="term-title">${title}</span><br/><br/>
            <span class="term-info">OUTPUT LOG:</span><br/><span class="term-desc">${problem}</span><br/><br/>
            <span class="term-success">> [ exit code 0 ] process execution successful.</span>
          `;

          if (desktopOutput) {
            gsap.killTweensOf(desktopOutput);
            gsap.to(desktopOutput, { text: { value: logHTML }, duration: 1.2, ease: "none" });
          }
        });
      });
    });

    // ==========================================
    // --- MOBILE GSAP LOGIC ---
    // ==========================================
    mm.add("(max-width: 767px)", () => {
      let mobileTl = gsap.timeline({ scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=300%" } });
      mobileTl.to(".intro-text", { opacity: 0, x: -30, duration: 1 }, 0)
        .to(".scroll-icon-wrapper", { opacity: 0, duration: 0.5 }, 0)
        .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);
      mobileTl.to(".portrait-wrapper", { x: "-35vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
        .to(".bio-text", { opacity: 1, x: 0, duration: 1, ease: "power1.out" }, 1.5);
      mobileTl.to({}, { duration: 1.5 });

      const mobileCmds = document.querySelectorAll('.mobile-cmd');
      let activeMobileIndex = -1;

      mobileCmds.forEach((cmd, index) => {
        cmd.addEventListener('click', () => {
          const el = cmd as HTMLElement;
          if (activeMobileIndex === index) return; 
          
          if (activeMobileIndex !== -1) {
             const prevWrapper = document.getElementById(`mobile-output-${activeMobileIndex}`);
             const prevContent = prevWrapper?.querySelector('.mobile-output-content');
             const prevCursor = prevWrapper?.querySelector('.mobile-cursor');
             if(prevContent && prevWrapper && prevCursor) {
               gsap.killTweensOf(prevContent);
               gsap.to(prevWrapper, { height: 0, duration: 0.4, ease: "power2.inOut" });
               (prevCursor as HTMLElement).style.display = 'none';
               mobileCmds[activeMobileIndex].classList.remove('active-cmd');
             }
          }

          activeMobileIndex = index;
          el.classList.add('active-cmd');

          const wrapper = document.getElementById(`mobile-output-${index}`);
          const content = wrapper?.querySelector('.mobile-output-content');
          const cursor = wrapper?.querySelector('.mobile-cursor');
          
          const date = el.getAttribute('data-date');
          const title = el.getAttribute('data-title');
          const company = el.getAttribute('data-company');
          const problem = el.getAttribute('data-problem');

          const logHTML = `
            <span class="term-date">[ ${date} ]</span><br/>
            <span class="term-process">TARGET_ORG:</span> <span class="term-title">${company}</span><br/>
            <span class="term-process">EXEC_ROLE:</span> <span class="term-title">${title}</span><br/><br/>
            <span class="term-info">OUTPUT:</span> <span class="term-desc">${problem}</span><br/><br/>
            <span class="term-success">> execution successful.</span>
          `;

          if(content && wrapper && cursor) {
            gsap.set(content, { text: "" }); 
            (cursor as HTMLElement).style.display = 'inline-block';
            gsap.to(wrapper, { height: "auto", duration: 0.4, ease: "power2.inOut", onComplete: () => {
                gsap.to(content, { text: { value: logHTML }, duration: 1.2, ease: "none" });
              }
            });
          }
        });
      });
    });

    const serviceCards = gsap.utils.toArray(".service-anim-card");
    serviceCards.forEach((card) => {
      gsap.from(card as Element, { opacity: 0, y: 50, duration: 0.8, ease: "power2.out", scrollTrigger: { trigger: card as Element, start: "top 85%" } });
    });

    gsap.from(".projects-flip-track-section", { opacity: 0, y: 40, duration: 0.8, ease: "power2.out", scrollTrigger: { trigger: ".projects-flip-track-section", start: "top 85%" } });
    gsap.from(".bento-card", { opacity: 0, y: 40, stagger: 0.15, duration: 0.8, ease: "power2.out", scrollTrigger: { trigger: ".bento-grid", start: "top 85%" } });

    const subtitles = ["Full-Stack Digital Marketer & Web Developer", "SEO Marketing Specialist", "Bespoke WordPress Architect", "Precision Paid Media Strategist", "Data-Driven Growth Engineer"];
    let subIndex = 0;
    const dynamicSubtitle = document.querySelector(".dynamic-subtitle");

    if (dynamicSubtitle) {
      gsap.delayedCall(3, function changeText() {
        gsap.to(dynamicSubtitle, { y: -15, opacity: 0, duration: 0.5, ease: "power2.in", onComplete: () => {
            subIndex = (subIndex + 1) % subtitles.length;
            dynamicSubtitle.textContent = subtitles[subIndex];
            gsap.fromTo(dynamicSubtitle, { y: 15, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" });
            gsap.delayedCall(3, changeText);
          }
        });
      });
    }

    // --- Form Submission Feedback ---
    const inquiryForm = document.getElementById("inquiryForm");
    const submitBtn = document.getElementById("submitBtn");

    if (inquiryForm && submitBtn) {
      inquiryForm.addEventListener("submit", () => {
        submitBtn.innerHTML = "Transmitting...";
        submitBtn.style.opacity = "0.7";
        submitBtn.style.pointerEvents = "none"; // Locks the button to prevent double-clicks
      });
    }
  </script>
</BaseLayout>

