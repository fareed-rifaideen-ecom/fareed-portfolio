---
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/600.css';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer</title>
    <meta name="title" content="Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer" />
    <meta name="description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />
    <meta name="author" content="Fareed M. Rifaideen" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fareed-rifaideen.netlify.app/" />
    <meta property="og:title" content="Fareed M. Rifaideen | Portfolio" />
    <meta property="og:description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />
    
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://fareed-rifaideen.netlify.app/" />
    <meta property="twitter:title" content="Fareed M. Rifaideen | Portfolio" />
    <meta property="twitter:description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />

    <link rel="canonical" href="https://fareed-rifaideen.netlify.app/" />
  </head>
  <body>
    
    <header class="site-header">
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.svg" alt="Fareed M. Rifaideen Logo" />
        </a>
        <nav>
          <a href="mailto:fareed.rifaideen@gmail.com" class="contact-btn">Let's Talk</a>
        </nav>
      </div>
    </header>

    <section class="hero">
      <div class="container">
        <h1>Fareed M. Rifaideen</h1>
        <h2>Full-Stack Digital Marketer & Web Developer</h2>
      </div>
    </section>

    <section class="profile-section">
      <div class="profile-container">
        
        <div class="profile-image-wrapper">
          <img src="/profile.jpg" alt="Fareed Profile" class="profile-img" /> 
        </div>

        <div class="profile-text-wrapper">
          <p class="bio">
            Drawing on a foundational background in financial operations and resource allocation, I engineer digital marketing strategies that are both technically robust and highly cost-effective.
          </p>
          <p class="bio">
            As a Certified Digital Marketing Professional (CDMP), I specialize in the intersection of technical SEO, bespoke WordPress and WooCommerce development, and precision Meta Ads.
          </p>
        </div>

      </div>
    </section>

    <section class="projects-section">
      <div class="container">
        <h2 class="section-title">Featured Projects</h2>
        
        <div class="projects-grid">
          {allProjects.map((project) => (
            <div class="project-card">
              <h3>{project.data.title}</h3>
              <p>{project.data.summary}</p>
              
              <div class="tech-tags">
                {project.data.techStack.map((tech) => (
                  <span class="tag">{tech}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-content">
        <p>© {new Date().getFullYear()} Fareed M. Rifaideen. All rights reserved.</p>
        <div class="social-links">
          <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/fareed-rifaideen-ecom" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from '@studio-freight/lenis';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      });

      function raf(time) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);

      let mm = gsap.matchMedia();

      mm.add("(min-width: 768px)", () => {
        let tl = gsap.timeline({
          scrollTrigger: {
            trigger: ".profile-section",
            pin: true,
            scrub: 1,
            start: "top top",
            end: "+=150%"
          }
        });

        tl.to(".profile-image-wrapper", { x: "-35vw", ease: "none" })
          .to(".profile-text-wrapper", { x: "25vw", opacity: 1, ease: "none" }, "<");
      });

      mm.add("(max-width: 767px)", () => {
        gsap.to(".profile-text-wrapper", {
          opacity: 1,
          y: 0,
          scrollTrigger: {
            trigger: ".profile-text-wrapper",
            start: "top 80%",
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #050505;
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-primary);
    font-family: 'Hanken Grotesk', sans-serif;
    margin: 0;
    overflow-x: hidden;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header Styling */
  .site-header {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 2rem 0;
    z-index: 100;
    mix-blend-mode: difference;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* Updated Logo Image Styling */
  .logo img {
    height: 35px; /* Adjust this number if your logo looks too big or too small */
    width: auto;
    display: block;
  }

  .contact-btn {
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid #fff;
    padding: 0.6rem 1.5rem;
    border-radius: 50px;
    font-size: 0.85rem;
    transition: all 0.3s ease;
  }

  .contact-btn:hover {
    background-color: #fff;
    color: #000;
  }

  /* Hero Styling */
  .hero {
    height: 100vh;
    display: flex;
    align-items: center;
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 8vw, 6rem);
    letter-spacing: -0.04em;
    margin: 0;
    line-height: 1;
  }

  h2 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(1.2rem, 3vw, 2rem);
    color: var(--text-secondary);
    margin-top: 1rem;
  }

  /* Profile Section Styling */
  .profile-section {
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .profile-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .profile-image-wrapper {
    position: absolute;
    width: 400px;
    height: 500px;
    z-index: 2;
    filter: grayscale(100%) contrast(1.1);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-text-wrapper {
    position: absolute;
    width: 500px;
    opacity: 0; 
    z-index: 1;
  }

  .bio {
    color: var(--text-secondary);
    font-size: 1.2rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  /* Projects Section Styling */
  .projects-section {
    padding: 10rem 0 5rem 0;
    background-color: var(--bg-color);
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    margin-bottom: 4rem;
    color: var(--text-primary);
  }

  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .project-card {
    border-top: 1px solid #333;
    padding-top: 2rem;
  }

  .project-card h3 {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    color: var(--text-primary);
    margin: 0 0 1rem 0;
  }

  .project-card p {
    color: var(--text-secondary);
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 800px;
    margin: 0;
  }

  .tech-tags {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 1rem;
    border: 1px solid #333;
    color: var(--text-secondary);
    transition: all 0.3s ease;
  }

  .tag:hover {
    color: var(--text-primary);
    border-color: var(--text-primary);
  }

  /* Footer Styling */
  .site-footer {
    border-top: 1px solid #1a1a1a;
    padding: 3rem 0;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-content p {
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .social-links {
    display: flex;
    gap: 2rem;
  }

  .social-links a {
    color: var(--text-primary);
    text-decoration: none;
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }

  .social-links a:hover {
    color: var(--text-secondary);
  }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .profile-container {
      flex-direction: column;
    }
    
    .profile-image-wrapper {
      position: relative;
      width: 90%;
      height: 400px;
      margin-bottom: 2rem;
    }

    .profile-text-wrapper {
      position: relative;
      width: 90%;
      transform: translateY(30px);
    }

    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>