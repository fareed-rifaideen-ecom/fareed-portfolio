---
// src/pages/index.astro
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg'; 
import BaseLayout from '../layouts/BaseLayout.astro';
import 'swiper/css';
import 'swiper/css/pagination';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
const carouselProjects = allProjects;

const allExperience = await getCollection('experience');
allExperience.sort((a, b) => a.data.order - b.data.order);

const allEducation = await getCollection('education');
allEducation.sort((a, b) => a.data.order - b.data.order);

const ethosEntries = await getCollection('ethos');
const ethosData = ethosEntries[0];
const { Content: EthosContent } = await render(ethosData);

let fetchedServices = [];
try {
  fetchedServices = await getCollection('services');
} catch (e) {
  console.warn("Services collection missing or error. Using fallback.");
}

const fallbackServices = [
  { data: { title: "Full-Stack SEO", command: "execute_seo", summary: "I architect comprehensive search engine strategies from the server to the front end. By combining deep technical audits, semantic site structure, and rigorous keyword gap analyses, I drive high-intent organic traffic directly to your bottom line.", techStack: ["Technical SEO", "SEMrush", "Ahrefs", "Schema Markup"], order: 1 } },
  { data: { title: "Data-Driven Marketing", command: "execute_marketing", summary: "Leveraging a decade of background in financial operations, I treat ad budgets like business investments. I engineer precision paid media campaigns across Meta and Google, utilizing AI-driven trend analysis and real-time data to ruthlessly optimize for maximum ROAS.", techStack: ["Meta Ads", "Google Ads", "GA4", "HubSpot"], order: 2 } },
  { data: { title: "Custom Web Development", command: "execute_development", summary: "I craft bespoke, conversion-optimized digital storefronts. Moving beyond basic templates, I combine sleek UI/UX design with custom WordPress, WooCommerce, and PHP backend development to ensure a flawless, lightning-fast user experience across all devices.", techStack: ["WordPress", "WooCommerce", "PHP", "CSS"], order: 3 } }
];

const allServices = (fetchedServices && fetchedServices.length > 0) ? fetchedServices : fallbackServices;
allServices.sort((a: any, b: any) => a.data.order - b.data.order);
---

<BaseLayout 
  title="Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer"
  description="Architecting high-performance digital ecosystems. Specializing in comprehensive SEO, bespoke WordPress development, and precision Full-Stack Digital Marketing strategies."
>
    
  <Image src={profileImg} alt="" class="ghost-watermark" id="bg-portrait" loading="lazy" />

  <header class="site-header">
    <div class="header-container">
      <a href="/" class="logo">
        <img src="/favicon.svg" alt="Fareed Logo" />
      </a>
      <nav class="nav-links">
        <a href="https://wa.me/9717775962" class="contact-btn" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href="#contact-modal" class="contact-btn modal-trigger">Let's Talk</a>
      </nav>
    </div>
  </header>

  <section class="cinematic-hero">
    <div class="cinematic-container">
      <div class="intro-text">
        <h1>Fareed M.<br/>Rifaideen</h1>
        <h2 class="dynamic-subtitle-wrapper">I'm a <span class="dynamic-subtitle">Full-Stack Digital Marketer & Web Developer</span></h2>
      </div>
      <div class="scroll-icon-wrapper">
        <img src="/scroll-Icon.svg" alt="Scroll Down" class="scroll-icon" />
      </div>
      <div class="portrait-wrapper">
        <Image src={profileImg} alt="Fareed Profile" class="portrait-img hero-portrait" loading="eager" /> 
      </div>
      <div class="bio-text">
        <p class="bio">
          I build digital marketing systems that make sense for the bottom line. With ten years of experience in financial operations, I treat marketing budgets like business investments.
        </p>
        <p class="bio">
          As a Full-Stack Marketer and Web Developer, I combine technical SEO, custom WordPress development, and targeted ads to build digital spaces that solve problems and generate real returns.
        </p>
      </div>
    </div>
  </section>

  <!-- Sticky Scroll Editorial Deck (Services) -->
  <section class="services-sticky-section" id="services">
    <div class="container">
      <div class="sticky-editorial-layout">
        
        <div class="sticky-sidebar">
          <div class="sticky-content">
            <h2 class="section-title">What I Do</h2>
            <p class="sticky-description">
              I engineer digital growth by combining technical precision with targeted marketing strategies. Here is exactly how my brain can make you money.
            </p>
            <a href="#contact-modal" class="btn-solid modal-trigger sticky-cta">Start a Project ↗</a>
          </div>
        </div>

        <div class="scrolling-cards-container">
          {allServices.map((service: any, index: number) => (
            <div class="editorial-service-card glass-panel service-anim-card">
              <div class="service-card-header">
                <span class="service-number">0{index + 1}</span>
                <h3 class="service-title">{service.data.title}</h3>
              </div>
              <div class="service-card-body">
                <p class="service-pitch">{service.data.summary}</p>
                <div class="tech-tags">
                  {service.data.techStack.map((tech: string) => (
                    <span class="tag">{tech}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- 3D Flip Track Carousel (Projects) -->
  <section class="projects-flip-track-section" id="projects">
    <div class="container">
      <div class="projects-header-wrapper">
        <div class="label-pill">
          <span class="pill-dot"></span>
          <span>Featured Work</span>
        </div>
        <h2 class="massive-projects-title">Engineered for<br/>Growth & Scale.</h2>
      </div>
    </div>

    <div class="swiper flip-projects-swiper">
      <div class="swiper-wrapper">
        {carouselProjects.map((project: any) => (
          <div class="swiper-slide flip-project-card">
            <div class="flip-card-inner">
              
              <!-- State A: Front (Text & Tags) -->
              <div class="flip-card-front glass-panel">
                <h3 class="proj-front-title">{project.data.title}</h3>
                <p class="proj-front-summary">{project.data.summary}</p>
                <div class="tech-tags">
                  {project.data.techStack.slice(0, 3).map((tech: string) => (
                    <span class="tag pill-tag">{tech}</span>
                  ))}
                </div>
              </div>

              <!-- State B: Back (Logo & Button) -->
              <div class="flip-card-back glass-panel">
                <img src={project.data.image} alt={`${project.data.title} Logo`} class="project-logo bw-logo" loading="lazy" decoding="async" />
                <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="btn-solid view-project-btn">View Live URL</a>
              </div>

            </div>
          </div>
        ))}
      </div>
      <div class="swiper-pagination flip-pagination"></div>
    </div>
  </section>

  <!-- Career Slider Section -->
  <section class="experience-section">
    <div class="container">
      <h2 class="section-title">Career Journey</h2>
      
      <div class="career-ruler-wrapper" id="career-scroll-box">
        <div class="career-ruler-track">
          <div class="career-ruler-line"></div>
          
          {allExperience.map((job: any) => (
            <div class="ruler-card tooltip-trigger" data-tooltip={job.data.problemStatement}>
              <div class="ruler-dot"></div>
              <div class="ruler-content glass-panel">
                <span class="timeline-date">{job.data.date}</span>
                <h3>{job.data.title}</h3>
                <h4>{job.data.company}</h4>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="slider-controls-container">
        <input type="range" id="career-slider" class="custom-monochrome-slider" min="0" max="100" value="0" />
      </div>

    </div>
  </section>

  <div id="global-tooltip" class="glass-panel hidden-tooltip">
    <p id="tooltip-text"></p>
  </div>

  <!-- Bento Section -->
  <section class="bento-section">
    <div class="container">
      <h2 class="section-title">Arsenal & Education</h2>
      <div class="bento-grid">
        <div class="bento-card skills-card">
          <h3>Technical Stack</h3>
          <div class="tech-tags">
            <span class="tag">Digital Strategy</span>
            <span class="tag">Technical SEO</span>
            <span class="tag">Meta Ads & PPC</span>
            <span class="tag">Google Ads & SEM</span>
            <span class="tag">Data Analytics (GA4)</span>
            <span class="tag">WordPress & WooCommerce</span>
            <span class="tag">PHP</span>
            <span class="tag">E-commerce Optimization</span>
            <span class="tag">AI-Driven Trend Analysis</span>
            <span class="tag">Campaign Performance Monitoring</span>
          </div>
        </div>

        <div class="bento-card cert-card">
          <h3>Professional Memberships</h3>
          <p>Member of Chartered Management Institute (MCMI)</p>
          <span class="bento-meta">CMI, UK</span>
        </div>

        {allEducation.map((edu: any) => (
          <div class="bento-card edu-card">
            <h3>{edu.data.degree}</h3>
            <p>{edu.data.institution}</p>
            <span class="bento-meta">{edu.data.date}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="ethos-section">
    <div class="container">
      <div class="ethos-box">
        <h2>{ethosData.data.title}</h2>
        <div class="ethos-content">
          <EthosContent />
          <a href={ethosData.data.buttonLink} class="contact-btn ethos-btn modal-trigger">{ethosData.data.buttonText}</a>
        </div>
      </div>
    </div>
  </section>

  <footer class="site-footer">
    <div class="container footer-content">
      <p>© {new Date().getFullYear()} Fareed M. Rifaideen. All rights reserved.</p>
      <div class="social-links">
        <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
        <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href="https://github.com/fareed-rifaideen-ecom" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </footer>

  <!-- Contact Modal -->
  <div class="modal-overlay" id="contactModal">
    <div class="modal-box">
      <button class="modal-close" id="closeModal">✕</button>
      <h3 class="modal-title">Start a Conversation</h3>
      <p class="modal-desc">Tell me about the problem you are trying to solve.</p>
      <form name="project-inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="brutalist-form">
        <p class="hidden">
          <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
        </p>
        <div class="input-group">
          <input type="text" name="name" id="name" required placeholder=" " />
          <label for="name">Your Name</label>
        </div>
        <div class="input-group">
          <input type="email" name="email" id="email" required placeholder=" " />
          <label for="email">Email Address</label>
        </div>
        <div class="input-group">
          <textarea name="message" id="message" rows="4" required placeholder=" "></textarea>
          <label for="message">Project Details</label>
        </div>
        <button type="submit" class="contact-btn submit-btn">Send Inquiry</button>
      </form>
    </div>
  </div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from '@studio-freight/lenis';
    import Swiper from 'swiper';
    import { Pagination, Autoplay } from 'swiper/modules';

    gsap.registerPlugin(ScrollTrigger);

    // --- Smooth Scrolling ---
    const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
    function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);

    // --- Background Portrait Opacity Tether ---
    gsap.to("#bg-portrait", {
      opacity: 0,
      scrollTrigger: {
        trigger: ".services-sticky-section",
        start: "top center",
        end: "top top",
        scrub: true
      }
    });

    // --- 3D Flip Track Carousel Logic ---
    new Swiper('.flip-projects-swiper', {
      modules: [Pagination, Autoplay],
      slidesPerView: 'auto',
      centeredSlides: true,
      spaceBetween: 80, // INCREASED GAP: Clean separation between cards
      loop: true,
      speed: 1000, 
      autoplay: { 
        delay: 3000, 
        disableOnInteraction: false, 
        pauseOnMouseEnter: true 
      },
      pagination: { 
        el: '.flip-pagination', 
        clickable: true 
      }
    });

    // Mobile specific script for handling 3D click flips
    const flipCards = document.querySelectorAll('.flip-project-card');
    flipCards.forEach(card => {
      card.addEventListener('click', () => {
        if (window.innerWidth <= 768) {
          card.classList.toggle('is-flipped');
          
          flipCards.forEach(otherCard => {
            if (otherCard !== card) {
              otherCard.classList.remove('is-flipped');
            }
          });
        }
      });
    });

    // --- Horizontal Career Slider Logic ---
    const scrollBox = document.getElementById('career-scroll-box');
    const slider = document.getElementById('career-slider') as HTMLInputElement;

    if (scrollBox && slider) {
      slider.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        const maxScroll = scrollBox.scrollWidth - scrollBox.clientWidth;
        scrollBox.scrollLeft = (Number(target.value) / 100) * maxScroll;
        target.style.setProperty('--val', target.value + '%');
      });

      scrollBox.addEventListener('scroll', () => {
        const maxScroll = scrollBox.scrollWidth - scrollBox.clientWidth;
        if(maxScroll > 0) {
            const val = (scrollBox.scrollLeft / maxScroll) * 100;
            slider.value = val.toString();
            slider.style.setProperty('--val', val + '%');
        }
      });
    }

    // --- Global Interactive Tooltip Logic ---
    const tooltip = document.getElementById('global-tooltip');
    const tooltipText = document.getElementById('tooltip-text');
    const triggerCards = document.querySelectorAll('.tooltip-trigger');

    triggerCards.forEach(card => {
      card.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        if (window.innerWidth > 768 && tooltip && tooltipText) {
          tooltipText.textContent = card.getAttribute('data-tooltip');
          tooltip.classList.remove('hidden-tooltip');
          tooltip.style.left = (mouseEvent.clientX + 20) + 'px';
          tooltip.style.top = (mouseEvent.clientY + 20) + 'px';
        }
      });

      card.addEventListener('mouseleave', () => {
        if(tooltip) tooltip.classList.add('hidden-tooltip');
      });

      card.addEventListener('click', () => {
        if (window.innerWidth <= 768 && tooltip && tooltipText) {
          tooltipText.textContent = card.getAttribute('data-tooltip');
          tooltip.classList.remove('hidden-tooltip');
          tooltip.classList.add('mobile-modal');
          setTimeout(() => tooltip.classList.add('hidden-tooltip'), 4000);
        }
      });
    });

    let mm = gsap.matchMedia();

    // --- Desktop GSAP ---
    mm.add("(min-width: 768px)", () => {
      let tl = gsap.timeline({
        scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=150%" }
      });
      tl.to(".intro-text", { opacity: 0, x: -50, duration: 1 }, 0)
        .to(".scroll-icon-wrapper", { opacity: 0, y: 20, duration: 0.5 }, 0)
        .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);
      tl.to(".portrait-wrapper", { x: "-25vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
        .to(".bio-text", { opacity: 1, x: 0, duration: 1, ease: "power1.out" }, 1.5);
    });

    // --- Mobile GSAP ---
    mm.add("(max-width: 767px)", () => {
      let mobileTl = gsap.timeline({
        scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=150%" }
      });
      mobileTl.to(".intro-text", { opacity: 0, y: 30, duration: 1 }, 0)
        .to(".scroll-icon-wrapper", { opacity: 0, duration: 0.5 }, 0)
        .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0);
      mobileTl.to(".portrait-wrapper", { x: "-35vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
        .to(".bio-text", { opacity: 1, y: 0, duration: 1, ease: "power1.out" }, 1.5);
    });

    const serviceCards = gsap.utils.toArray(".service-anim-card");
    serviceCards.forEach((card) => {
      gsap.from(card as Element, {
        opacity: 0,
        y: 50,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: card as Element,
          start: "top 85%"
        }
      });
    });

    gsap.from(".projects-flip-track-section", { opacity: 0, y: 40, duration: 0.8, ease: "power2.out", scrollTrigger: { trigger: ".projects-flip-track-section", start: "top 85%" } });
    gsap.from(".bento-card", { opacity: 0, y: 40, stagger: 0.15, duration: 0.8, ease: "power2.out", scrollTrigger: { trigger: ".bento-grid", start: "top 85%" } });

    // --- Contact Modal Logic ---
    const modal = document.getElementById("contactModal");
    const openBtns = document.querySelectorAll(".modal-trigger");
    const closeBtn = document.getElementById("closeModal");

    const openModal = (e: Event) => {
      e.preventDefault();
      lenis.stop(); 
      gsap.to(modal, { opacity: 1, pointerEvents: "auto", duration: 0.4, ease: "power2.out" });
      gsap.fromTo(".modal-box", { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, delay: 0.1, ease: "power2.out" });
    };
    const closeModal = () => {
      gsap.to(modal, { opacity: 0, pointerEvents: "none", duration: 0.4, ease: "power2.in" });
      lenis.start(); 
    };

    openBtns.forEach(btn => btn.addEventListener("click", openModal));
    closeBtn?.addEventListener("click", closeModal);
    modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

    // --- Dynamic Subtitle ---
    const subtitles = ["Full-Stack Digital Marketer & Web Developer", "Technical SEO Specialist", "Bespoke WordPress Architect", "Precision Paid Media Strategist", "Data-Driven Growth Engineer"];
    let subIndex = 0;
    const dynamicSubtitle = document.querySelector(".dynamic-subtitle");

    if (dynamicSubtitle) {
      gsap.delayedCall(3, function changeText() {
        gsap.to(dynamicSubtitle, {
          y: -15, opacity: 0, duration: 0.5, ease: "power2.in",
          onComplete: () => {
            subIndex = (subIndex + 1) % subtitles.length;
            dynamicSubtitle.textContent = subtitles[subIndex];
            gsap.fromTo(dynamicSubtitle, { y: 15, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" });
            gsap.delayedCall(3, changeText);
          }
        });
      });
    }
  </script>
</BaseLayout>

<style is:global>
  :root {
    --bg-color: #050505;
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
    --accent: #fff;
  }
  body { background-color: var(--bg-color); color: var(--text-primary); font-family: 'Hanken Grotesk', sans-serif; margin: 0; overflow-x: hidden; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  /* Header */
  .site-header { position: fixed; top: 0; width: 100%; padding: 2rem 0; z-index: 100; mix-blend-mode: difference; }
  .header-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; }
  .logo img { height: 35px; width: auto; display: block; }
  .nav-links { display: flex; gap: 1rem; align-items: center; }
  .contact-btn {
    font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; color: #fff; text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; padding: 0.6rem 1.5rem;
    border-radius: 50px; font-size: 0.85rem; transition: all 0.3s ease; cursor: pointer; background: transparent;
  }
  .contact-btn:hover { background-color: #fff; color: #000; }

  /* Ghost Watermark */
  .ghost-watermark {
    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
    height: 120vh; width: auto; min-width: 100vw; object-fit: cover;
    opacity: 0.03; mix-blend-mode: luminosity; pointer-events: none; z-index: 0;
  }

  /* Cinematic Section */
  .cinematic-hero { height: 100vh; width: 100vw; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center; z-index: 1;}
  .cinematic-container { position: relative; width: 100%; max-width: 1200px; height: 100%; margin: 0 auto; display: flex; align-items: center; }
  .intro-text { position: absolute; left: 2rem; z-index: 10; }
  .intro-text h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(3rem, 7vw, 6.5rem); letter-spacing: -0.02em; margin: 0; line-height: 1.1; }
  .dynamic-subtitle-wrapper { font-family: 'Hanken Grotesk', sans-serif; font-weight: 400; font-size: clamp(1rem, 2vw, 1.5rem); color: var(--text-secondary); margin-top: 1rem; display: flex; align-items: center; gap: 0.4rem;}
  .dynamic-subtitle { display: inline-block; color: var(--text-primary); font-weight: 600; }
  
  .scroll-icon-wrapper { position: absolute; bottom: 3rem; left: 2rem; z-index: 10; }
  .scroll-icon { width: 30px; height: auto; opacity: 0.7; animation: bounce 2s infinite; }
  @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-10px); } 60% { transform: translateY(-5px); } }
  .portrait-wrapper { position: absolute; height: 100vh; width: 100vw; top: 0; left: 0; display: flex; align-items: center; justify-content: center; z-index: 1; transform: translateX(35vw); }
  .portrait-img { height: 100%; width: 100%; max-width: 800px; object-fit: cover; object-position: center; transition: filter 1s ease; }
  .bio-text { position: absolute; right: 2rem; width: 450px; z-index: 10; opacity: 0; transform: translateX(50px); }
  .bio { color: var(--text-secondary); font-size: 1.2rem; line-height: 1.7; margin-bottom: 1.5rem; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 3rem; margin-bottom: 4rem; color: var(--text-primary); }

  /* Generic Glass Panel */
  .glass-panel { background: linear-gradient(135deg, rgba(25, 25, 25, 0.4) 0%, rgba(10, 10, 10, 0.8) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255, 255, 255, 0.1); border-left: 1px solid rgba(255, 255, 255, 0.1); border-bottom: 1px solid rgba(255, 255, 255, 0.02); border-right: 1px solid rgba(255, 255, 255, 0.02); box-shadow: 0 15px 35px rgba(0, 0, 0, 0.8); border-radius: 16px; }

  /* Shared Button Styles */
  .btn-solid { font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; font-size: 0.85rem; background: #fff; color: #000; padding: 0.8rem 2rem; border-radius: 50px; text-decoration: none; transition: all 0.3s ease; border: 1px solid #fff; display: inline-block; text-align: center; }
  .btn-solid:hover { background: transparent; color: #fff; }

  /* --- Sticky Editorial Services Section --- */
  .services-sticky-section { padding: 5rem 0; position: relative; z-index: 5; }
  .sticky-editorial-layout { display: flex; justify-content: space-between; align-items: flex-start; }
  
  .sticky-sidebar { width: 35%; position: sticky; top: 25vh; }
  .sticky-content { display: flex; flex-direction: column; align-items: flex-start; }
  .sticky-sidebar .section-title { margin-bottom: 1.5rem; }
  .sticky-description { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.7; margin-bottom: 2.5rem; }
