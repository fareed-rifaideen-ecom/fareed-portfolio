---
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/600.css';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import profileImg from '../assets/profile.jpg'; 
import 'swiper/css';
import 'swiper/css/effect-coverflow';
import 'swiper/css/navigation';

const allProjects = await getCollection('projects');
allProjects.sort((a, b) => a.data.order - b.data.order);
// Array duplication ensures flawless infinite looping in Swiper
const carouselProjects = [...allProjects, ...allProjects];

const allExperience = await getCollection('experience');
allExperience.sort((a, b) => a.data.order - b.data.order);

const allEducation = await getCollection('education');
allEducation.sort((a, b) => a.data.order - b.data.order);

const ethosEntries = await getCollection('ethos');
const ethosData = ethosEntries[0];
const { Content: EthosContent } = await render(ethosData);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer</title>
    <meta name="title" content="Fareed M. Rifaideen | Full-Stack Digital Marketer & Web Developer" />
    <meta name="description" content="Architecting high-performance digital ecosystems through technical SEO, bespoke WordPress development, and precision Meta Ads." />
    <meta name="author" content="Fareed M. Rifaideen" />
    <link rel="canonical" href="https://fareed-rifaideen.netlify.app/" />
  </head>
  <body>
    
    <Image src={profileImg} alt="" class="ghost-watermark" id="bg-portrait" />

    <header class="site-header">
      <div class="header-container">
        <a href="/" class="logo">
          <img src="/favicon.svg" alt="Fareed Logo" />
        </a>
        <nav class="nav-links">
          <a href="https://wa.me/9717775962" class="contact-btn" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="#contact-modal" class="contact-btn modal-trigger">Let's Talk</a>
        </nav>
      </div>
    </header>

    <section class="cinematic-hero">
      <div class="cinematic-container">
        <div class="intro-text">
          <h1>Fareed M.<br/>Rifaideen</h1>
          <h2 class="dynamic-subtitle">Full-Stack Digital Marketer & Web Developer</h2>
        </div>
        <div class="scroll-icon-wrapper">
          <img src="/scroll-Icon.svg" alt="Scroll Down" class="scroll-icon" />
        </div>
        <div class="portrait-wrapper">
          <Image src={profileImg} alt="Fareed Profile" class="portrait-img hero-portrait" /> 
        </div>
        <div class="bio-text">
          <p class="bio">
            I build digital marketing systems that make sense for the bottom line. With ten years of experience in financial operations, I treat marketing budgets like business investments.
          </p>
          <p class="bio">
            As a Full-Stack Marketer and Web Developer, I combine technical SEO, custom WordPress development, and targeted ads to build digital spaces that solve problems and generate real returns.
          </p>
        </div>
      </div>
    </section>

    <section class="projects-section">
      <div class="ambient-glow"></div>
      
      <div class="container">
        <h2 class="section-title">Featured Projects</h2>
        
        <div class="mobile-swipe-prompt">
          <span>&lt; Swipe &gt;</span>
        </div>

        <div class="projects-split-layout">
          <div class="projects-info-panel">
            <h3 id="active-project-title">{allProjects[0].data.title}</h3>
            <p id="active-project-summary">{allProjects[0].data.summary}</p>
            <div class="tech-tags" id="active-project-tags">
              {allProjects[0].data.techStack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
            <a href={allProjects[0].data.liveUrl} id="active-project-link" target="_blank" class="contact-btn view-project-btn">View Live Project</a>
          </div>

          <div class="projects-visual-panel">
            <div class="swiper projects-swiper">
              <div class="swiper-wrapper mobile-wallet-stack">
                {carouselProjects.map((project, index) => (
                  <div class="swiper-slide project-card-wrapper wallet-card" data-index={index % allProjects.length}>
                    <div class="flip-card-inner">
                      
                      <div class="flip-card-front glass-panel project-image-card">
                        <div class="hidden-data" data-title={project.data.title} data-summary={project.data.summary} data-link={project.data.liveUrl} data-tags={project.data.techStack.join(',')}></div>
                        
                        <img src={project.data.image} alt={`${project.data.title} Logo`} class="project-logo desktop-front-logo" />
                        
                        <div class="mobile-project-content">
                          <h3>{project.data.title}</h3>
                          <a href={project.data.liveUrl} target="_blank" class="mobile-link">View Project →</a>
                        </div>
                      </div>

                      <div class="flip-card-back glass-panel">
                        <img src={project.data.image} alt={`${project.data.title} Logo`} class="project-logo" />
                        <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="contact-btn view-project-btn">View Live Project</a>
                      </div>

                    </div>
                  </div>
                ))}
              </div>
              <div class="swiper-button-prev custom-arrow"></div>
              <div class="swiper-button-next custom-arrow"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="experience-section">
      <div class="container">
        <h2 class="section-title">Career Journey</h2>
        
        <div class="career-split-layout">
          <div class="career-index-panel">
            {allExperience.map((job) => (
              <div class="index-year" data-year={job.data.date}>{job.data.date.split(' ')[0]}</div>
            ))}
          </div>

          <div class="career-cards-panel">
            {allExperience.map((job) => (
              <div class="timeline-item drawer-card">
                <div class="timeline-dot"></div>
                <div class="drawer-header">
                  <div class="drawer-titles">
                    <h3>{job.data.title}</h3>
                    <h4>{job.data.company}</h4>
                  </div>
                  <span class="timeline-date desktop-hide">{job.data.date}</span>
                  <span class="mobile-expand-icon desktop-hide">+</span>
                </div>
                <div class="timeline-hover-summary drawer-body">
                  <p class="problem-statement">{job.data.problemStatement}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="bento-section">
      <div class="container">
        <h2 class="section-title">Arsenal & Education</h2>
        <div class="bento-grid">
          <div class="bento-card skills-card">
            <h3>Technical Stack</h3>
            <div class="tech-tags">
              <span class="tag">Technical SEO</span>
              <span class="tag">Meta Ads</span>
              <span class="tag">Google Ads</span>
              <span class="tag">WordPress</span>
              <span class="tag">PHP</span>
              <span class="tag">Data Analytics</span>
            </div>
          </div>

          <div class="bento-card cert-card">
            <h3>Professional Memberships</h3>
            <p>Member of Chartered Management Institute (MCMI)</p>
            <span class="bento-meta">CMI, UK</span>
          </div>

          {allEducation.map((edu) => (
            <div class="bento-card edu-card">
              <h3>{edu.data.degree}</h3>
              <p>{edu.data.institution}</p>
              <span class="bento-meta">{edu.data.date}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="ethos-section">
      <div class="container">
        <div class="ethos-box">
          <h2>{ethosData.data.title}</h2>
          <div class="ethos-content">
            <EthosContent />
            <a href={ethosData.data.buttonLink} class="contact-btn ethos-btn modal-trigger">{ethosData.data.buttonText}</a>
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-content">
        <p>© {new Date().getFullYear()} Fareed M. Rifaideen. All rights reserved.</p>
        <div class="social-links">
          <a href="https://wa.me/9717775962" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="https://www.linkedin.com/in/fareed03" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          <a href="https://github.com/fareed-rifaideen-ecom" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </footer>

    <div class="modal-overlay" id="contactModal">
      <div class="modal-box">
        <button class="modal-close" id="closeModal">✕</button>
        <h3 class="modal-title">Start a Conversation</h3>
        <p class="modal-desc">Tell me about the problem you are trying to solve.</p>
        <form name="project-inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="brutalist-form">
          <p class="hidden">
            <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
          </p>
          <div class="input-group">
            <input type="text" name="name" id="name" required placeholder=" " />
            <label for="name">Your Name</label>
          </div>
          <div class="input-group">
            <input type="email" name="email" id="email" required placeholder=" " />
            <label for="email">Email Address</label>
          </div>
          <div class="input-group">
            <textarea name="message" id="message" rows="4" required placeholder=" "></textarea>
            <label for="message">Project Details</label>
          </div>
          <button type="submit" class="contact-btn submit-btn">Send Inquiry</button>
        </form>
      </div>
    </div>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';
      import Lenis from '@studio-freight/lenis';
      import Swiper from 'swiper';
      import { EffectCoverflow, Navigation, Autoplay } from 'swiper/modules';

      gsap.registerPlugin(ScrollTrigger);

      // --- Smooth Scrolling ---
      const lenis = new Lenis({ duration: 1.2, easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)) });
      function raf(time: number) { lenis.raf(time); requestAnimationFrame(raf); }
      requestAnimationFrame(raf);

      let mm = gsap.matchMedia();

      // --- Background Portrait Opacity Tether ---
      gsap.to("#bg-portrait", {
        opacity: 0,
        scrollTrigger: {
          trigger: ".projects-section",
          start: "top center", // Fades to zero when projects hit center screen
          end: "top top",
          scrub: true
        }
      });

      // --- Responsive JavaScript Logic ---
      mm.add("(min-width: 768px)", () => {
        
        // DESKTOP: Linear Continuous Swiper Setup
        const projectSwiper = new Swiper('.projects-swiper', {
          modules: [EffectCoverflow, Navigation, Autoplay],
          effect: 'coverflow',
          grabCursor: true,
          centeredSlides: true,
          slidesPerView: 'auto',
          loop: true,
          speed: 4000, // Smooth continuous speed
          autoplay: {
            delay: 0, // No delay creates the linear ticker effect
            disableOnInteraction: false,
            pauseOnMouseEnter: true, // Pauses perfectly on hover for interaction/flipping
          },
          coverflowEffect: { rotate: 45, stretch: 0, depth: 250, modifier: 1, slideShadows: true },
          navigation: {
            nextEl: '.swiper-button-next',
            prevEl: '.swiper-button-prev',
          }
        });

        // Update Sticky Text on Slide Change
        projectSwiper.on('slideChange', function () {
          const activeSlide = projectSwiper.slides[projectSwiper.activeIndex];
          const dataNode = activeSlide.querySelector('.hidden-data') as HTMLElement;
          
          if(dataNode) {
            document.getElementById('active-project-title')!.innerText = dataNode.dataset.title || '';
            document.getElementById('active-project-summary')!.innerText = dataNode.dataset.summary || '';
            document.getElementById('active-project-link')!.setAttribute('href', dataNode.dataset.link || '#');
            
            const tagsArray = (dataNode.dataset.tags || '').split(',');
            const tagsHTML = tagsArray.map(tag => `<span class="tag">${tag}</span>`).join('');
            document.getElementById('active-project-tags')!.innerHTML = tagsHTML;
          }
        });

        // DESKTOP: Hero Animations
        let tl = gsap.timeline({ scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=300%" } });
        tl.to(".intro-text", { opacity: 0, x: -50, duration: 1 }, 0)
          .to(".scroll-icon-wrapper", { opacity: 0, y: 20, duration: 0.5 }, 0)
          .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0)
          .to(".hero-portrait", { opacity: 0, duration: 0.5 }, 1) 
        tl.to(".portrait-wrapper", { x: "-25vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
          .to(".bio-text", { opacity: 1, x: 0, duration: 1, ease: "power1.out" }, 1.5);

        // DESKTOP: Sticky Career Index Highlights
        gsap.utils.toArray(".timeline-item").forEach((item) => {
          ScrollTrigger.create({
            trigger: item as Element,
            start: "top center",
            end: "bottom center",
            onEnter: () => updateActiveYear(item as HTMLElement),
            onEnterBack: () => updateActiveYear(item as HTMLElement)
          });
        });

        function updateActiveYear(item: HTMLElement) {
          document.querySelectorAll('.index-year').forEach(el => el.classList.remove('active'));
          const yearEl = document.querySelector(`.index-year[data-year="${item.querySelector('.timeline-date')?.textContent}"]`);
          if(yearEl) yearEl.classList.add('active');
        }
      });

      mm.add("(max-width: 767px)", () => {
        // MOBILE: Hero Animations
        let mobileTl = gsap.timeline({ scrollTrigger: { trigger: ".cinematic-hero", pin: true, scrub: 1.5, start: "top top", end: "+=250%" } });
        mobileTl.to(".intro-text", { opacity: 0, y: 30, duration: 1 }, 0)
          .to(".scroll-icon-wrapper", { opacity: 0, duration: 0.5 }, 0)
          .to(".portrait-wrapper", { x: "0vw", duration: 1.2, ease: "power1.inOut" }, 0)
          .to(".hero-portrait", { opacity: 0, duration: 0.5 }, 1)
        mobileTl.to(".portrait-wrapper", { x: "-35vw", duration: 1.2, ease: "power1.inOut" }, 1.5)
          .to(".bio-text", { opacity: 1, y: 0, duration: 1, ease: "power1.out" }, 1.5);

        // MOBILE: Swipe Prompt Fade
        const prompt = document.querySelector('.mobile-swipe-prompt') as HTMLElement;
        document.querySelector('.projects-section')?.addEventListener('touchstart', () => {
          if (prompt) prompt.style.opacity = '0';
        }, { once: true });

        // MOBILE: Drawer Accordion Logic
        const drawers = document.querySelectorAll('.drawer-card');
        drawers.forEach(drawer => {
          drawer.addEventListener('click', () => {
            drawers.forEach(d => { if(d !== drawer) d.classList.remove('is-open'); });
            drawer.classList.toggle('is-open');
          });
        });
      });

      // --- Contact Modal Logic ---
      const modal = document.getElementById("contactModal");
      const openBtns = document.querySelectorAll(".modal-trigger");
      const closeBtn = document.getElementById("closeModal");

      const openModal = (e: Event) => {
        e.preventDefault();
        lenis.stop(); 
        gsap.to(modal, { opacity: 1, pointerEvents: "auto", duration: 0.4, ease: "power2.out" });
        gsap.fromTo(".modal-box", { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, delay: 0.1, ease: "power2.out" });
      };

      const closeModal = () => {
        gsap.to(modal, { opacity: 0, pointerEvents: "none", duration: 0.4, ease: "power2.in" });
        lenis.start(); 
      };

      openBtns.forEach(btn => btn.addEventListener("click", openModal));
      closeBtn?.addEventListener("click", closeModal);
      modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

      // --- Dynamic Rotating Subtitle ---
      const subtitles = ["Full-Stack Digital Marketer & Web Developer", "Technical SEO Specialist", "Bespoke WordPress Architect", "Precision Paid Media Strategist", "Data-Driven Growth Engineer"];
      let subIndex = 0;
      const dynamicSubtitle = document.querySelector(".dynamic-subtitle");

      if (dynamicSubtitle) {
        gsap.delayedCall(3, function changeText() {
          gsap.to(dynamicSubtitle, {
            y: -15, opacity: 0, duration: 0.5, ease: "power2.in",
            onComplete: () => {
              subIndex = (subIndex + 1) % subtitles.length;
              dynamicSubtitle.textContent = subtitles[subIndex];
              gsap.fromTo(dynamicSubtitle, { y: 15, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, ease: "power2.out" });
              gsap.delayedCall(3, changeText);
            }
          });
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #050505;
    --text-primary: #F5F5F5;
    --text-secondary: #A3A3A3;
    --accent: #fff;
  }
  body { background-color: var(--bg-color); color: var(--text-primary); font-family: 'Hanken Grotesk', sans-serif; margin: 0; overflow-x: hidden; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 2; }

  /* Ghost Watermark */
  .ghost-watermark {
    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
    height: 120vh; width: auto; min-width: 100vw; object-fit: cover;
    opacity: 0.03; mix-blend-mode: luminosity; pointer-events: none; z-index: 0;
  }

  /* Header */
  .site-header { position: fixed; top: 0; width: 100%; padding: 2rem 0; z-index: 100; mix-blend-mode: difference; }
  .header-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; justify-content: space-between; align-items: center; }
  .logo img { height: 35px; width: auto; display: block; }
  .nav-links { display: flex; gap: 1rem; align-items: center; }
  .contact-btn {
    font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; color: #fff; text-decoration: none;
    text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; padding: 0.6rem 1.5rem;
    border-radius: 50px; font-size: 0.85rem; transition: all 0.3s ease; cursor: pointer; background: transparent;
  }
  .contact-btn:hover { background-color: #fff; color: #000; }

  /* Cinematic Section */
  .cinematic-hero { height: 100vh; width: 100vw; overflow: hidden; position: relative; display: flex; align-items: center; justify-content: center; z-index: 1;}
  .cinematic-container { position: relative; width: 100%; max-width: 1200px; height: 100%; margin: 0 auto; display: flex; align-items: center; }
  .intro-text { position: absolute; left: 2rem; z-index: 10; }
  .intro-text h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(3rem, 7vw, 6.5rem); letter-spacing: -0.02em; margin: 0; line-height: 1.1; }
  .intro-text h2 { font-family: 'Hanken Grotesk', sans-serif; font-weight: 400; font-size: clamp(1rem, 2vw, 1.5rem); color: var(--text-secondary); margin-top: 1rem; }
  .dynamic-subtitle { display: block; min-height: 3rem; }
  .scroll-icon-wrapper { position: absolute; bottom: 3rem; left: 2rem; z-index: 10; }
  .scroll-icon { width: 30px; height: auto; opacity: 0.7; animation: bounce 2s infinite; }
  @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-10px); } 60% { transform: translateY(-5px); } }
  .portrait-wrapper { position: absolute; height: 100vh; width: 100vw; top: 0; left: 0; display: flex; align-items: center; justify-content: center; z-index: 1; transform: translateX(35vw); }
  .portrait-img { height: 100%; width: 100%; max-width: 800px; object-fit: cover; object-position: center; }
  .bio-text { position: absolute; right: 2rem; width: 450px; z-index: 10; opacity: 0; transform: translateX(50px); }
  .bio { color: var(--text-secondary); font-size: 1.2rem; line-height: 1.7; margin-bottom: 1.5rem; }
  .section-title { font-family: 'Syne', sans-serif; font-size: 3rem; margin-bottom: 4rem; color: var(--text-primary); }

  /* --- Projects Layout Restructure --- */
  .projects-section { padding: 8rem 0 5rem 0; position: relative; }
  .ambient-glow { position: absolute; top: 50%; right: 0; transform: translateY(-50%); width: 60vw; height: 90vh; border-radius: 50%; background: radial-gradient(circle at center, rgba(99, 102, 241, 0.1) 0%, transparent 60%); filter: blur(40px); z-index: 1; pointer-events: none; }
  
  .mobile-swipe-prompt { display: none; }

  .projects-split-layout { display: flex; gap: 4rem; position: relative; z-index: 2; align-items: center; }
  .projects-info-panel { width: 40%; position: sticky; top: 30vh; height: fit-content; display: flex; flex-direction: column; gap: 1.5rem; }
  .projects-info-panel h3 { font-family: 'Syne', sans-serif; font-size: 2.5rem; margin: 0; color: var(--text-primary); }
  .projects-info-panel p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; margin: 0; }
  .tech-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1rem; }
  .tag { font-family: 'Hanken Grotesk', sans-serif; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; padding: 0.4rem 0.8rem; border: 1px solid rgba(255, 255, 255, 0.15); color: var(--text-secondary); }
  .view-project-btn { width: fit-content; }

  .projects-visual-panel { width: 60%; }
  .projects-swiper { width: 100%; padding: 2rem 0; overflow: visible; }
  
  /* CRITICAL: Forces the continuous linear transition globally for desktop Swiper */
  @media (min-width: 768px) {
    .projects-swiper .swiper-wrapper {
      -webkit-transition-timing-function: linear !important;
      transition-timing-function: linear !important;
    }
  }

  .swiper-slide { width: 320px; height: 420px; perspective: 1000px; }
  
  .flip-card-inner { position: relative; width: 100%; height: 100%; transition: transform 0.8s cubic-bezier(0.4, 0.2, 0.2, 1); transform-style: preserve-3d; }
  .swiper-slide-active:hover .flip-card-inner { transform: rotateY(180deg); }

  .project-image-card { 
    width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center;
  }
  .glass-panel {
    position: absolute; width: 100%; height: 100%; backface-visibility: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 2.5rem; background: linear-gradient(135deg, rgba(25, 25, 25, 0.4) 0%, rgba(10, 10, 10, 0.7) 100%); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-top: 1px solid rgba(255, 255, 255, 0.2); border-left: 1px solid rgba(255, 255, 255, 0.15); border-bottom: 1px solid rgba(255, 255, 255, 0.02); border-right: 1px solid rgba(255, 255, 255, 0.02); box-shadow: 0 15px 35px rgba(0, 0, 0, 0.8); border-radius: 12px;
  }
  .flip-card-back { transform: rotateY(180deg); }
  
  .project-logo { max-width: 80%; max-height: 150px; object-fit: contain; }
  .desktop-front-logo { opacity: 0.7; transition: opacity 0.3s ease; filter: grayscale(1); }
  .swiper-slide-active .desktop-front-logo { opacity: 1; filter: grayscale(0); }

  .hidden-data { display: none; }
  .mobile-project-content { display: none; }

  /* Minimalist Swiper Arrows */
  .custom-arrow { color: #fff; opacity: 0; transition: opacity 0.3s ease; }
  .custom-arrow::after { font-size: 1.5rem !important; font-weight: bold; }
  .projects-section:hover .custom-arrow { opacity: 0.5; }
  .projects-section:hover .custom-arrow:hover { opacity: 1; }

  /* --- Career Index Layout Restructure --- */
  .experience-section { padding: 8rem 0; }
