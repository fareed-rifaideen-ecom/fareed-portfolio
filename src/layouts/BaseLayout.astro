---
// src/layouts/BaseLayout.astro
import '@fontsource/syne/700.css';
import '@fontsource/syne/800.css';
import '@fontsource/hanken-grotesk/400.css';
import '@fontsource/hanken-grotesk/600.css';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';

// Define the properties this layout accepts
interface Props {
  title: string;
  description: string;
  image?: string;
}

const { 
  title, 
  description, 
  image = "https://fareed-rifaideen.netlify.app/og-image.jpg" 
} = Astro.props;

// Automatically grabs the exact URL of whatever page the user is on
const url = Astro.url.href;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Full-Stack Digital Marketer, Comprehensive SEO, Web Developer Dubai, Meta Ads Expert, PPC Management, Fareed M. Rifaideen" />
    <meta name="author" content="Fareed M. Rifaideen" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={url} />

    <!-- Open Graph / LinkedIn / Facebook / WhatsApp -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Theme Color for Mobile Browsers -->
    <meta name="theme-color" content="#050505" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Technical SEO JSON-LD Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Fareed M. Rifaideen",
        "jobTitle": "Full-Stack Digital Marketer & Web Developer",
        "url": "https://fareed-rifaideen.netlify.app/",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Dubai",
          "addressCountry": "AE"
        },
        "sameAs": [
          "https://www.linkedin.com/in/fareed03",
          "https://github.com/fareed-rifaideen-ecom"
        ],
        "knowsAbout": [
          "Search Engine Optimization (SEO)",
          "Full-Stack Digital Marketing",
          "Data Analytics",
          "Performance Marketing",
          "E-commerce Optimization",
          "WordPress & WooCommerce Development"
        ]
      }
    </script>
  </head>
  <body>
    <!-- The content of your pages will be injected here -->
    <slot />

    <!-- GLOBAL STYLES (Applies to every page using this layout) -->
    <style is:global>
      :root {
        --bg-color: #050505;
        --text-primary: #F5F5F5;
        --text-secondary: #A3A3A3;
        --accent: #fff;

        /* THE GOLDEN TYPOGRAPHIC SCALE */
        --step--2: 0.75rem; 
        --step--1: 0.85rem; 
        --step-0: 1rem;     
        --step-1: 1.15rem;  
        --step-2: 1.5rem;   
        --step-3: 2.5rem;   
        --step-4: 3rem;     
        --step-5: clamp(3rem, 5vw, 4.5rem); 

        --section-gap-desktop: 8rem;
        --section-gap-mobile: 4rem;
      }

      body { 
        background-color: var(--bg-color); 
        color: var(--text-primary); 
        font-family: 'Hanken Grotesk', sans-serif; 
        margin: 0; 
        overflow-x: hidden; 
      }
      
      .container { 
        max-width: 1200px; 
        margin: 0 auto; 
        padding: 0 2rem; 
        position: relative; 
        z-index: 2; 
      }
      
      .global-padding { 
        padding: var(--section-gap-desktop) 0; 
      }

      @media (max-width: 768px) {
        :root { 
          --step-2: 1.3rem; 
          --step-3: 2rem;   
          --step-4: 2.5rem; 
        }
        .global-padding { 
          padding: var(--section-gap-mobile) 0; 
        }
      }
    </style>
  </body>
</html>