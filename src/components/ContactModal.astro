---
// src/components/ContactModal.astro
---
<div class="modal-overlay" id="contactModal">
  <div class="modal-box">
    <button class="modal-close" id="closeModal">✕</button>
    <h3 class="modal-title">Start a Conversation</h3>
    <p class="modal-desc">What primary business objective are we tackling today?</p>
    <form id="inquiryForm" name="project-inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/success" class="brutalist-form">
      <p class="hidden">
        <label>Don’t fill this out if you're human: <input name="bot-field" /></label>
      </p>
      <div class="input-group">
        <input type="text" name="name" id="name" required placeholder=" " />
        <label for="name">Your Name</label>
      </div>
      <div class="input-group">
        <input type="email" name="email" id="email" required placeholder=" " />
        <label for="email">Email Address</label>
      </div>
      <div class="input-group">
        <textarea name="message" id="message" rows="4" required placeholder=" "></textarea>
        <label for="message">Project Details</label>
      </div>
      <button type="submit" id="submitBtn" class="contact-btn submit-btn">Send Brief</button>
    </form>
  </div>
</div>

<style>
  .modal-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(5, 5, 5, 0.85); backdrop-filter: blur(8px); z-index: 1000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; }
  .modal-box { background: #050505; border: 1px solid #333; padding: 4rem; width: 90%; max-width: 500px; position: relative; }
  .modal-close { position: absolute; top: 1.5rem; right: 1.5rem; background: none; border: none; color: var(--text-secondary); font-size: 1.5rem; cursor: pointer; transition: color 0.3s ease; }
  .modal-close:hover { color: var(--text-primary); }
  .modal-title { font-family: 'Syne', sans-serif; font-size: 2.5rem; margin: 0 0 0.5rem 0; color: #fff; }
  .modal-desc { color: var(--text-secondary); font-size: 1rem; margin-bottom: 2rem; }
  .brutalist-form { display: flex; flex-direction: column; gap: 2rem; }
  .hidden { display: none; }
  .input-group { position: relative; }
  .input-group input, .input-group textarea { width: 100%; background: transparent; border: none; border-bottom: 1px solid #333; padding: 1rem 0; color: var(--text-primary); font-family: 'Hanken Grotesk', sans-serif; font-size: 1rem; outline: none; transition: border-color 0.3s ease; resize: none; }
  .input-group label { position: absolute; left: 0; top: 1rem; color: var(--text-secondary); pointer-events: none; transition: all 0.3s ease; font-size: 1rem; }
  .input-group input:focus, .input-group textarea:focus { border-bottom-color: var(--text-primary); }
  .input-group input:focus ~ label, .input-group input:not(:placeholder-shown) ~ label, .input-group textarea:focus ~ label, .input-group textarea:not(:placeholder-shown) ~ label { top: -10px; font-size: 0.75rem; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.05em; }
  .submit-btn { width: 100%; margin-top: 1rem; font-size: 1rem; padding: 1rem; font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; border: 1px solid #fff; border-radius: 50px; background: #fff; color: #000; cursor: pointer; transition: all 0.3s ease; }
  .submit-btn:hover { background: transparent; color: #fff; }

  @media (max-width: 768px) {
    .modal-box { padding: 2rem; }
  }
</style>

<script>
  import gsap from 'gsap';

  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("contactModal");
    const closeBtn = document.getElementById("closeModal");

    if(modal) {
      const openModal = (e: Event) => {
        e.preventDefault();
        if ((window as any).lenis) { (window as any).lenis.stop(); } 
        else { document.body.style.overflow = "hidden"; }
        gsap.to(modal, { opacity: 1, pointerEvents: "auto", duration: 0.4, ease: "power2.out" });
        gsap.fromTo(".modal-box", { y: 50, opacity: 0 }, { y: 0, opacity: 1, duration: 0.5, delay: 0.1, ease: "power2.out" });
      };

      const closeModal = () => {
        gsap.to(modal, { opacity: 0, pointerEvents: "none", duration: 0.4, ease: "power2.in" });
        if ((window as any).lenis) { (window as any).lenis.start(); } 
        else { document.body.style.overflow = "auto"; }
      };

      // EVENT DELEGATION: Captures dynamic terminal GSAP clicks
      document.body.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest(".modal-trigger")) {
          openModal(e);
        }
      });

      closeBtn?.addEventListener("click", closeModal);
      modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
    }

    // --- Form Submission Feedback ---
    const inquiryForm = document.getElementById("inquiryForm");
    const submitBtn = document.getElementById("submitBtn");

    if (inquiryForm && submitBtn) {
      inquiryForm.addEventListener("submit", () => {
        submitBtn.innerHTML = "Transmitting...";
        submitBtn.style.opacity = "0.7";
        submitBtn.style.pointerEvents = "none";
      });
    }
  });
</script>